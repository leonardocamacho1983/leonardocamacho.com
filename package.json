{
  "name": "camacho-website",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "astro dev",
    "build": "astro check && astro build",
    "preview": "astro preview",
    "astro": "astro",
    "content:ops": "bash scripts/content-workflow.sh",
    "seed": "node --env-file=.env scripts/seed-sanity.mjs",
    "translate:categories": "node --env-file=.env scripts/translate-categories.mjs",
    "translate:categories:apply": "node --env-file=.env scripts/translate-categories.mjs --apply",
    "lint:design": "bash scripts/lint-design.sh",
    "test:llm:hardening": "bash scripts/test-runprompt-hardening.sh",
    "test:system:validation": "npm run test:llm:hardening && npm run test:publish:review:draft-detection && npm run test:refresh:workflow && npm run test:seo:acceptance && env -u CODEX_SANDBOX_NETWORK_DISABLED -u SANDBOX_NETWORK_DISABLED npm run test:editorial:benchmarks && env -u CODEX_SANDBOX_NETWORK_DISABLED -u SANDBOX_NETWORK_DISABLED npm run test:localization:regression",
    "test:editorial:benchmarks": "bash scripts/test-editorial-benchmarks.sh",
    "test:seo:metadata": "bash scripts/test-seo-metadata-quality.sh",
    "test:seo:head:contract": "bash scripts/test-seo-head-contract.sh",
    "test:seo:schema": "bash scripts/test-seo-schema.sh",
    "test:seo:tracking": "bash scripts/test-seo-tracking.sh",
    "test:growth:kpi": "bash scripts/test-growth-kpi.sh",
    "test:growth:stability": "bash scripts/test-growth-kpi-stability.sh",
    "test:create-content:cli:seo-opportunity": "bash scripts/test-create-content-cli-seo-opportunity.sh",
    "test:publish:internal-link-preflight": "bash scripts/test-publish-internal-link-preflight.sh",
    "test:publish:review:draft-detection": "bash scripts/test-publish-review-draft-detection.sh",
    "test:refresh:workflow": "bash scripts/test-refresh-content.sh",
    "test:seo:acceptance": "npm run test:seo:metadata && npm run test:seo:head:contract && npm run test:seo:schema && npm run test:seo:tracking && npm run test:create-content:cli:seo-opportunity && npm run test:publish:internal-link-preflight",
    "test:localization:regression": "bash scripts/test-localization-longform-regression.sh",
    "test:localization:regression:failure": "bash scripts/test-localization-longform-regression-failure.sh",
    "test:localization:regression:advisory-failure": "bash scripts/test-localization-longform-regression-failure.sh",
    "test:localization:regression:workflow-leakage-failure": "bash scripts/test-localization-longform-regression-workflow-leakage-failure.sh",
    "og:export:previews": "npx tsx scripts/export-og-previews.ts",
    "seo:track": "node --experimental-strip-types scripts/run-seo-tracking.ts",
    "growth:kpi:summary": "node --experimental-strip-types scripts/run-growth-kpi-summary.ts",
    "growth:kpi:stability": "node --experimental-strip-types scripts/run-growth-kpi-stabilization.ts"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.78.0",
    "@astrojs/react": "^4.4.0",
    "@astrojs/vercel": "^8.2.5",
    "@fontsource/dm-sans": "^5.2.8",
    "@fontsource/playfair-display": "^5.2.8",
    "@portabletext/to-html": "^2.0.17",
    "@resvg/resvg-js": "^2.6.2",
    "@sanity/client": "^7.20.0",
    "@sanity/image-url": "^2.1.1",
    "@sanity/vision": "^5.19.0",
    "@vercel/analytics": "^1.6.1",
    "@vercel/speed-insights": "^1.3.1",
    "astro": "^5.13.5",
    "astro-portabletext": "^0.11.1",
    "dotenv": "^17.3.1",
    "openai": "^6.32.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "sanity": "^5.19.0",
    "satori": "^0.26.0",
    "styled-components": "^6.3.11"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.6",
    "@types/node": "^22.18.0",
    "typescript": "^5.9.2"
  }
}
