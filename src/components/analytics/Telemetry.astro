---
interface Props {
  enableAutocapture?: boolean;
  enablePageview?: boolean;
  enablePageleave?: boolean;
  enableSessionRecording?: boolean;
  sessionRecordingSampleRate?: number;
  enableSurveys?: boolean;
}

const {
  enableAutocapture,
  enablePageview,
  enablePageleave,
  enableSessionRecording,
  sessionRecordingSampleRate,
  enableSurveys,
} = Astro.props;

const flagValue = (propValue: boolean | undefined, envValue: string | undefined, fallback: string) =>
  typeof propValue === "boolean" ? String(propValue) : envValue || fallback;

const numberValue = (
  propValue: number | undefined,
  envValue: string | undefined,
  fallback: string,
) => (typeof propValue === "number" ? String(propValue) : envValue || fallback);

const posthogKey = import.meta.env.PUBLIC_POSTHOG_KEY || "";
const posthogHost = import.meta.env.PUBLIC_POSTHOG_HOST || "https://us.i.posthog.com";
const posthogAutocapture = flagValue(
  enableAutocapture,
  import.meta.env.PUBLIC_POSTHOG_ENABLE_AUTOCAPTURE,
  "true",
);
const posthogPageview = flagValue(enablePageview, import.meta.env.PUBLIC_POSTHOG_ENABLE_PAGEVIEW, "true");
const posthogPageleave = flagValue(
  enablePageleave,
  import.meta.env.PUBLIC_POSTHOG_ENABLE_PAGELEAVE,
  "true",
);
const posthogSessionRecording = flagValue(
  enableSessionRecording,
  import.meta.env.PUBLIC_POSTHOG_ENABLE_SESSION_RECORDING,
  "true",
);
const posthogSessionRecordingSampleRate = numberValue(
  sessionRecordingSampleRate,
  import.meta.env.PUBLIC_POSTHOG_SESSION_RECORDING_SAMPLE_RATE,
  "1",
);
const posthogSurveys = flagValue(enableSurveys, import.meta.env.PUBLIC_POSTHOG_ENABLE_SURVEYS, "true");
---

<script
  is:inline
  defer
  src="/js/telemetry.js"
  data-posthog-key={posthogKey}
  data-posthog-host={posthogHost}
  data-posthog-autocapture={posthogAutocapture}
  data-posthog-pageview={posthogPageview}
  data-posthog-pageleave={posthogPageleave}
  data-posthog-session-recording={posthogSessionRecording}
  data-posthog-session-recording-sample-rate={posthogSessionRecordingSampleRate}
  data-posthog-surveys={posthogSurveys}
></script>

<style is:global>
  .lc-consent-banner {
    position: fixed;
    z-index: 120;
    left: 50%;
    transform: translateX(-50%);
    width: min(940px, calc(100% - 20px));
    bottom: calc(14px + env(safe-area-inset-bottom));
    border: 1px solid rgba(205, 191, 177, 0.95);
    border-top: 2px solid rgba(181, 69, 58, 0.7);
    border-radius: 14px;
    background: linear-gradient(180deg, rgba(249, 245, 239, 0.98), rgba(242, 236, 227, 0.97));
    box-shadow: 0 16px 36px rgba(42, 34, 32, 0.2);
    padding: 14px 16px;
    display: grid;
    grid-template-columns: 1fr auto;
    align-items: center;
    gap: 12px;
    backdrop-filter: blur(6px);
  }

  .lc-consent-banner__text {
    min-width: 0;
  }

  .lc-consent-banner__title {
    margin: 0 0 4px;
    font-family: "Playfair Display", Georgia, serif;
    font-size: 18px;
    line-height: 1.1;
    color: #1a1715;
  }

  .lc-consent-banner__copy {
    margin: 0;
    font-family: "DM Sans", Arial, sans-serif;
    font-size: 13px;
    line-height: 1.5;
    color: #5a4f47;
  }

  .lc-consent-banner__link {
    color: #2a2220;
    font-weight: 500;
    text-underline-offset: 2px;
  }

  .lc-consent-banner__actions {
    display: flex;
    justify-content: flex-start;
    gap: 8px;
    flex-wrap: wrap;
  }

  .lc-consent-banner__btn {
    font-family: "DM Sans", Arial, sans-serif;
    font-size: 12px;
    font-weight: 600;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    border-radius: 8px;
    padding: 10px 14px;
    border: 1px solid #bfb09f;
    background: transparent;
    color: #2a2220;
    cursor: pointer;
    transition: background-color 0.18s ease, border-color 0.18s ease;
  }

  .lc-consent-banner__btn:hover {
    background: rgba(217, 205, 191, 0.28);
  }

  .lc-consent-banner__btn--primary {
    background: #b5453a;
    color: #fff;
    border-color: #b5453a;
  }

  .lc-consent-banner__btn--primary:hover {
    background: #a43e34;
    border-color: #a43e34;
  }

  @media (max-width: 760px) {
    .lc-consent-banner {
      width: min(940px, calc(100% - 14px));
      padding: 12px 13px;
      grid-template-columns: 1fr;
    }

    .lc-consent-banner__actions {
      width: 100%;
      justify-content: flex-start;
    }

    .lc-consent-banner__btn {
      flex: 1 1 calc(50% - 6px);
      min-width: 0;
    }

    .lc-consent-banner__title {
      font-size: 16px;
    }

    .lc-consent-banner__copy {
      font-size: 12px;
    }
  }
</style>
