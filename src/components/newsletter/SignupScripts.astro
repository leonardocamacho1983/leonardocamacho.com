<script is:inline>
  const trackEvent = (eventName, props = {}) => {
    if (typeof window.lcTrack !== 'function') return;
    window.lcTrack(eventName, {
      analytics_domain: 'growth',
      analytics_channel: 'client',
      ...props,
    });
  };

  const resolveKitLocale = (path) => {
    if (path.startsWith('/pt-br')) return 'pt_BR';
    if (path.startsWith('/pt-pt') || path.startsWith('/pt/')) return 'pt_PT';
    if (path.startsWith('/fr-fr') || path.startsWith('/fr/')) return 'fr_FR';
    if (path.startsWith('/en-gb')) return 'en_UK';
    return 'en_US';
  };

  const normalizeSubscriberId = (value) => {
    if (typeof value === 'string') return value.trim();
    if (typeof value === 'number') return String(value);
    return '';
  };

  const buildRedirectUrl = (targetPath, subscriberId) => {
    const nextUrl = new URL(targetPath, window.location.origin);
    if (subscriberId) {
      nextUrl.searchParams.set('ck_subscriber_id', subscriberId);
    }
    return `${nextUrl.pathname}${nextUrl.search}`;
  };

  const persistSubscriberId = (subscriberId) => {
    if (!subscriberId) return;
    try {
      window.sessionStorage.setItem('ck_subscriber_id', subscriberId);
    } catch {}
  };

  const submitNative = (formEl) => {
    if (!(formEl instanceof HTMLFormElement)) return;
    HTMLFormElement.prototype.submit.call(formEl);
  };

  const parseSubscribeStatusFromResponseUrl = (value) => {
    if (!value) return '';
    try {
      const parsed = new URL(value, window.location.origin);
      return (parsed.searchParams.get('status') || '').trim();
    } catch {
      return '';
    }
  };

  const attachLaunchSignupForm = () => {
    const launchForm = document.getElementById('launchSignupForm');
    if (!launchForm) return;

    launchForm.addEventListener('submit', async (e) => {
      e.preventDefault();

      const emailInput = launchForm.querySelector('input[type="email"]');
      const btn = launchForm.querySelector('button[type="submit"]');
      const errorEl = document.getElementById('launchError');
      const formWrap = document.getElementById('launchFormWrap');
      const successWrap = document.getElementById('launchSuccess');
      if (!emailInput || !btn) return;

      const email = emailInput.value.trim();
      const kitLocale = launchForm.dataset.kitLocale || resolveKitLocale(window.location.pathname);
      const welcomePath = launchForm.dataset.welcomePath || '/welcome';
      const revealDelay = Number(launchForm.dataset.revealDelayMs || '1400');
      const originalText = btn.textContent;

      btn.disabled = true;
      btn.textContent = 'Sending...';
      if (errorEl) errorEl.textContent = '';
      trackEvent('launch_submit_clicked');

      try {
        const res = await fetch('/api/subscribe', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({
            email,
            locale: kitLocale,
            source: 'launch-mode',
            path: window.location.pathname,
          }),
        });

        if (res.ok) {
          let subscriberId = '';
          try {
            const body = await res.json();
            subscriberId = normalizeSubscriberId(body?.subscriber_id);
          } catch {}

          persistSubscriberId(subscriberId);
          trackEvent('launch_subscribe_success');

          formWrap?.classList.add('is-hidden');
          successWrap?.classList.add('is-visible');
          window.setTimeout(() => {
            window.location.href = buildRedirectUrl(welcomePath, subscriberId);
          }, revealDelay);
          return;
        }

        trackEvent('launch_subscribe_failed', { reason: 'http_error', status: res.status });
        if (errorEl) errorEl.textContent = 'Something went wrong. Please try again.';
      } catch {
        trackEvent('launch_subscribe_failed', { reason: 'network_error' });
        if (errorEl) errorEl.textContent = 'Something went wrong. Please try again.';
      }

      btn.textContent = originalText;
      btn.disabled = false;
    });
  };

  const attachHomeSignupForm = () => {
    const homeForm = document.getElementById('signupForm');
    if (!homeForm) return;

    homeForm.addEventListener('submit', async (e) => {
      e.preventDefault();

      const emailInput = homeForm.querySelector('input[type="email"]');
      const btn = homeForm.querySelector('button[type="submit"]');
      if (!emailInput || !btn) return;

      const email = emailInput.value.trim();
      const originalText = btn.textContent;
      const path = window.location.pathname;
      const locale = resolveKitLocale(path);

      btn.disabled = true;
      btn.textContent = '...';
      trackEvent('home_subscribe_submit_clicked', { surface_type: 'home', path });

      try {
        const res = await fetch('/api/subscribe', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({
            email,
            locale,
            source: 'home',
            path,
          }),
        });

        if (res.ok) {
          let subscriberId = '';
          try {
            const body = await res.json();
            subscriberId = normalizeSubscriberId(body?.subscriber_id);
          } catch {}

          persistSubscriberId(subscriberId);
          trackEvent('home_subscribe_success', { surface_type: 'home', path });

          const prefix = path.startsWith('/pt-br') ? '/pt-br'
                       : path.startsWith('/pt-pt') || path.startsWith('/pt/') ? '/pt'
                       : path.startsWith('/fr-fr') || path.startsWith('/fr/') ? '/fr'
                       : '';
          window.location.href = buildRedirectUrl(`${prefix}/welcome`, subscriberId);
        } else {
          trackEvent('home_subscribe_failed', {
            surface_type: 'home',
            path,
            reason: 'http_error',
            status: res.status,
          });
          btn.textContent = 'TRY AGAIN';
          btn.disabled = false;
          setTimeout(() => { btn.textContent = originalText; }, 2000);
        }
      } catch {
        trackEvent('home_subscribe_failed', {
          surface_type: 'home',
          path,
          reason: 'network_error',
        });
        btn.textContent = 'TRY AGAIN';
        btn.disabled = false;
        setTimeout(() => { btn.textContent = originalText; }, 2000);
      }
    });
  };

  const attachWritingSignupForms = () => {
    const forms = Array.from(document.querySelectorAll('form.archive-newsletter__form[action="/api/newsletter/subscribe"]'));
    if (!forms.length) return;

    forms.forEach((writingForm) => {
      if (!(writingForm instanceof HTMLFormElement)) return;

      writingForm.addEventListener('submit', async (e) => {
        e.preventDefault();

        const submitButton = writingForm.querySelector('button[type="submit"]');
        const inputEmail = writingForm.querySelector('input[type="email"]');
        const originalButtonText = submitButton?.textContent || '';
        const path = window.location.pathname;

        trackEvent('writing_subscribe_submit_clicked', {
          surface_type: 'writing_index',
          path,
        });

        if (submitButton instanceof HTMLButtonElement) {
          submitButton.disabled = true;
          submitButton.textContent = '...';
        }

        if (!(inputEmail instanceof HTMLInputElement) || !inputEmail.value.trim()) {
          trackEvent('writing_subscribe_failed', {
            surface_type: 'writing_index',
            path,
            reason: 'missing_email',
          });
          if (submitButton instanceof HTMLButtonElement) {
            submitButton.disabled = false;
            submitButton.textContent = originalButtonText;
          }
          return;
        }

        try {
          const payload = {
            locale: String(new FormData(writingForm).get('locale') || ''),
            email: inputEmail.value.trim(),
            source: String(new FormData(writingForm).get('source') || 'writing'),
            path: String(new FormData(writingForm).get('path') || path),
          };
          const res = await fetch(writingForm.action, {
            method: 'POST',
            headers: {
              'Content-Type': 'application/json',
              Accept: 'application/json, text/plain, */*',
            },
            body: JSON.stringify(payload),
            credentials: 'same-origin',
          });

          if (!res.ok) {
            trackEvent('writing_subscribe_failed', {
              surface_type: 'writing_index',
              path,
              reason: 'http_error',
              status: res.status,
            });
            submitNative(writingForm);
            return;
          }

          const finalStatus = parseSubscribeStatusFromResponseUrl(res.url);
          if (finalStatus === 'subscribed') {
            trackEvent('writing_subscribe_success', {
              surface_type: 'writing_index',
              path,
            });
          } else {
            trackEvent('writing_subscribe_failed', {
              surface_type: 'writing_index',
              path,
              reason: finalStatus || 'unexpected_status',
            });
          }

          if (res.url) {
            window.location.href = res.url;
            return;
          }

          submitNative(writingForm);
        } catch {
          trackEvent('writing_subscribe_failed', {
            surface_type: 'writing_index',
            path,
            reason: 'network_error',
          });
          submitNative(writingForm);
        } finally {
          if (submitButton instanceof HTMLButtonElement) {
            submitButton.disabled = false;
            submitButton.textContent = originalButtonText;
          }
        }
      });
    });
  };

  attachLaunchSignupForm();
  attachHomeSignupForm();
  attachWritingSignupForms();
</script>
