---
import EditorialIllustration from "@/components/launch/EditorialIllustration.astro";
import SignupScripts from "@/components/newsletter/SignupScripts.astro";
import { copy as newsletterCopy } from "@/data/newsletter-copy";
import { mapHtmlLang } from "@/lib/format";
import { LOCALES, type LocaleKey } from "@/lib/locales";
import FlowLayout from "@/layouts/FlowLayout.astro";

interface Props {
  locale: LocaleKey;
}

const { locale } = Astro.props;

const COPY_KEY: Record<LocaleKey, string> = {
  "en-us": "en",
  "en-gb": "en",
  "pt-br": "pt-br",
  "pt-pt": "pt",
  "fr-fr": "fr",
};
const WELCOME_PATH: Record<LocaleKey, string> = {
  "en-us": "/welcome",
  "en-gb": "/welcome",
  "pt-br": "/pt-br/welcome",
  "pt-pt": "/pt/welcome",
  "fr-fr": "/fr/welcome",
};
const KIT_LOCALE: Record<LocaleKey, string> = {
  "en-us": "en_US",
  "en-gb": "en_UK",
  "pt-br": "pt_BR",
  "pt-pt": "pt_PT",
  "fr-fr": "fr_FR",
};

const nc = newsletterCopy[COPY_KEY[locale] || "en"];
const kitLocale = KIT_LOCALE[locale] || "en_US";
const welcomePath = WELCOME_PATH[locale] || "/welcome";
const [headlineLine1, headlineLine2 = ""] = nc.headline.split("\n");
const currentLocaleMeta = LOCALES.find((item) => item.key === locale) || LOCALES[0];
const launchRevealDelayMs = Number(import.meta.env.PUBLIC_LAUNCH_REVEAL_DELAY_MS || 1400);
const launchAlternates = LOCALES.map((item) => ({
  hrefLang: mapHtmlLang(item.key),
  href: `/${item.key}`,
}));
---

<FlowLayout
  title={`Leonardo Camacho — ${nc.headlineAccent}`}
  description={nc.supportingNote}
  lang={nc.lang}
  locale={locale}
  robots="index,follow"
  canonicalPath={`/${locale}`}
  alternateLinks={launchAlternates}
  xDefaultHref="/en-us"
>
  <div class="launch-page">
    <EditorialIllustration />

    <main class="launch-main">
      <section class="launch-content">
        <div class="launch-author">
          <span class="launch-author__line"></span>
          <span class="launch-author__name">Leonardo Camacho</span>
          <span class="launch-author__line"></span>
        </div>

        <h1 class="launch-headline">
          {headlineLine1}{headlineLine2 !== undefined && <br />}{headlineLine2}<em>{nc.headlineAccent}</em>
        </h1>

        <p class="launch-subhead">
          {nc.subhead1}<br />{nc.subhead2}
        </p>

        <div id="launchFormWrap" class="launch-form-wrap">
          <form
            class="launch-form"
            id="launchSignupForm"
            data-kit-locale={kitLocale}
            data-welcome-path={welcomePath}
            data-reveal-delay-ms={launchRevealDelayMs}
          >
            <input
              class="launch-input"
              type="email"
              name="email"
              required
              placeholder="your@email.com"
              autocomplete="email"
            />
            <button class="launch-submit" type="submit">{nc.ctaButton}</button>
          </form>
          <p class="launch-error" id="launchError" aria-live="polite"></p>
          <p class="launch-note">{nc.supportingNote}</p>
        </div>

        <div id="launchSuccess" class="launch-success" aria-live="polite">
          <div class="launch-success__badge">
            <svg width="12" height="12" viewBox="0 0 14 14" fill="none" aria-hidden="true">
              <path d="M3 7L6 10.5L11 4" stroke="white" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"></path>
            </svg>
          </div>
          <p class="launch-success__title">{nc.launchSuccessTitle}</p>
          <p class="launch-success__body">{nc.launchSuccessBody}</p>
        </div>

        <div class="launch-architecture" aria-label="What you'll receive">
          <span>{nc.navWriting}</span>
          <span class="launch-architecture__dot">◆</span>
          <span>{nc.navResearch}</span>
          <span class="launch-architecture__dot">◆</span>
          <span class="launch-architecture__accent">{nc.navLetter}</span>
          <span class="launch-architecture__dot">◆</span>
          <span>{nc.navStrategy}</span>
        </div>

        <div class="launch-meta">
          <span class="launch-date-label">{nc.launchDate}</span>
          <span class="launch-meta__dot">•</span>
          <details class="launch-language">
            <summary class="launch-language__summary">
              <span class="launch-language__flag">{currentLocaleMeta.flag}</span>
              <span class="launch-language__region">{currentLocaleMeta.key.split("-")[1].toUpperCase()}</span>
            </summary>
            <div class="launch-language__menu">
              {LOCALES.map((item) => (
                <a
                  href={`/${item.key}`}
                  class={`launch-language__option${item.key === locale ? " launch-language__option--active" : ""}`}
                  aria-current={item.key === locale ? "true" : undefined}
                >
                  <span>{item.flag}</span>
                  <span>{item.label}</span>
                </a>
              ))}
            </div>
          </details>
        </div>
      </section>
    </main>

    <div class="launch-thread" aria-hidden="true"></div>
  </div>

  <style>
    .launch-page {
      position: relative;
      width: 100%;
      min-height: 100vh;
      min-height: 100svh;
      overflow: hidden;
      background: var(--flow-cream);
      isolation: isolate;
    }

    .launch-main {
      position: relative;
      z-index: 1;
      min-height: 100vh;
      min-height: 100svh;
      display: flex;
      align-items: center;
      justify-content: center;
      padding: 36px 24px 52px;
    }

    .launch-content {
      width: min(680px, 100%);
      max-width: 100%;
      text-align: center;
      position: relative;
      z-index: 1;
    }

    .launch-author {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      gap: 16px;
      margin-bottom: 52px;
    }

    .launch-author__line {
      width: 52px;
      height: 1px;
      background: var(--flow-border);
    }

    .launch-author__name {
      font-family: var(--flow-font-ui);
      font-size: 10px;
      font-weight: 500;
      letter-spacing: 0.28em;
      text-transform: uppercase;
      color: var(--flow-muted);
    }

    .launch-headline {
      margin: 0;
      font-family: var(--flow-font-display);
      font-size: clamp(34px, 6.4vw, 56px);
      line-height: 1.08;
      font-weight: 400;
      color: var(--flow-near-black);
      letter-spacing: -0.02em;
    }

    .launch-headline em {
      font-style: italic;
      color: var(--flow-red);
    }

    .launch-subhead {
      margin: 16px auto 0;
      max-width: 440px;
      font-family: var(--flow-font-body);
      font-size: clamp(14px, 2.1vw, 16px);
      line-height: 1.75;
      color: var(--flow-muted);
    }

    .launch-form-wrap {
      margin-top: 28px;
    }

    .launch-form-wrap.is-hidden {
      display: none;
    }

    .launch-form {
      display: flex;
      max-width: 460px;
      margin: 0 auto;
      border: 1px solid var(--flow-border);
      border-radius: 8px;
      overflow: hidden;
      background: #f7f3ee;
      box-shadow: 0 2px 12px rgba(42, 42, 42, 0.05);
    }

    .launch-input {
      flex: 1;
      min-width: 0;
      border: none;
      background: transparent;
      color: var(--flow-body);
      font-family: var(--flow-font-ui);
      font-size: 14px;
      padding: 14px 16px;
      outline: none;
    }

    .launch-input::placeholder {
      color: #b5aea6;
    }

    .launch-submit {
      border: none;
      background: var(--flow-red);
      color: #fff;
      font-family: var(--flow-font-ui);
      font-size: 11px;
      font-weight: 600;
      letter-spacing: 0.08em;
      text-transform: uppercase;
      white-space: nowrap;
      padding: 14px 18px;
      cursor: pointer;
      transition: opacity 0.2s ease;
    }

    .launch-submit:hover {
      opacity: 0.88;
    }

    .launch-submit:disabled {
      opacity: 0.6;
      cursor: not-allowed;
    }

    .launch-error {
      min-height: 20px;
      margin-top: 8px;
      font-family: var(--flow-font-ui);
      font-size: 12px;
      color: var(--flow-red);
    }

    .launch-note {
      margin-top: 2px;
      font-family: var(--flow-font-body);
      font-size: 12px;
      font-style: italic;
      color: var(--flow-muted);
    }

    .launch-success {
      display: none;
      margin-top: 30px;
    }

    .launch-success.is-visible {
      display: block;
    }

    .launch-success__badge {
      width: 24px;
      height: 24px;
      margin: 0 auto 10px;
      border-radius: 999px;
      background: #6b8f71;
      display: flex;
      align-items: center;
      justify-content: center;
    }

    .launch-success__title {
      margin: 0;
      font-family: var(--flow-font-display);
      font-size: 16px;
      font-style: italic;
      color: var(--flow-near-black);
    }

    .launch-success__body {
      margin: 6px 0 0;
      font-family: var(--flow-font-ui);
      font-size: 12px;
      color: var(--flow-muted);
    }

    .launch-architecture {
      margin-top: 30px;
      display: flex;
      gap: 12px;
      align-items: center;
      justify-content: center;
      flex-wrap: wrap;
      max-width: 440px;
      margin-inline: auto;
      font-family: var(--flow-font-ui);
      font-size: 11px;
      letter-spacing: 0.06em;
      color: var(--flow-muted);
    }

    .launch-architecture span {
      white-space: nowrap;
    }

    .launch-architecture__accent {
      color: var(--flow-red);
      font-family: var(--flow-font-display);
      font-style: italic;
      letter-spacing: 0.02em;
    }

    .launch-architecture__dot {
      color: #8a7e76;
      opacity: 0.6;
      font-size: 7px;
      transform: translateY(-1px);
    }

    .launch-meta {
      margin-top: 24px;
      display: inline-flex;
      align-items: center;
      gap: 10px;
      flex-wrap: wrap;
      justify-content: center;
    }

    .launch-date-label {
      font-family: var(--flow-font-ui);
      font-size: 10px;
      font-weight: 500;
      letter-spacing: 0.18em;
      text-transform: uppercase;
      color: var(--flow-muted);
    }

    .launch-meta__dot {
      color: var(--flow-stone);
      opacity: 0.45;
      font-size: 8px;
    }

    .launch-language {
      position: relative;
    }

    .launch-language[open] .launch-language__summary {
      background: rgba(232, 226, 218, 0.9);
    }

    .launch-language__summary {
      list-style: none;
      cursor: pointer;
      border-radius: 8px;
      padding: 4px 8px;
      display: inline-flex;
      align-items: center;
      gap: 6px;
    }

    .launch-language__summary::-webkit-details-marker {
      display: none;
    }

    .launch-language__flag {
      font-size: 13px;
      line-height: 1;
    }

    .launch-language__region {
      font-family: var(--flow-font-ui);
      font-size: 10px;
      letter-spacing: 0.08em;
      color: var(--flow-muted);
    }

    .launch-language__menu {
      position: absolute;
      left: 50%;
      transform: translateX(-50%);
      bottom: calc(100% + 8px);
      min-width: 220px;
      border-radius: 12px;
      border: 1px solid var(--flow-border);
      background: #f7f3ee;
      box-shadow: 0 12px 40px rgba(42, 42, 42, 0.14);
      padding: 6px 0;
    }

    .launch-language__option {
      display: flex;
      align-items: center;
      gap: 10px;
      padding: 8px 12px;
      text-decoration: none;
      color: var(--flow-body);
      font-family: var(--flow-font-ui);
      font-size: 13px;
    }

    .launch-language__option:hover {
      background: rgba(232, 226, 218, 0.65);
    }

    .launch-language__option--active {
      color: var(--flow-red);
      font-weight: 500;
    }

    .launch-thread {
      position: absolute;
      left: 0;
      right: 0;
      bottom: 0;
      height: 2px;
      background: var(--flow-red);
      z-index: 2;
    }

    @media (max-width: 760px) {
      .launch-main {
        padding: calc(26px + env(safe-area-inset-top)) 20px calc(42px + env(safe-area-inset-bottom));
        align-items: flex-start;
      }

      .launch-author {
        margin-bottom: 42px;
      }

      .launch-author__line {
        width: 40px;
      }

      .launch-form {
        flex-direction: column;
        max-width: 100%;
      }

      .launch-submit {
        width: 100%;
      }

      .launch-note {
        margin-top: 10px;
      }

      .launch-meta {
        margin-top: 22px;
      }
    }

    @media (max-width: 540px) {
      .launch-content {
        width: min(420px, 100%);
      }

      .launch-author {
        gap: 10px;
        margin-bottom: 34px;
      }

      .launch-author__line {
        width: 30px;
      }

      .launch-author__name {
        font-size: 9px;
        letter-spacing: 0.2em;
      }

      .launch-headline {
        font-size: clamp(28px, 11vw, 42px);
        line-height: 1.1;
      }

      .launch-subhead {
        margin-top: 14px;
        font-size: 13px;
        line-height: 1.65;
        max-width: 320px;
      }

      .launch-form-wrap {
        margin-top: 24px;
      }

      .launch-input {
        padding: 16px 18px;
        font-size: 16px;
      }

      .launch-submit {
        padding: 16px 18px;
        font-size: 12px;
        letter-spacing: 0.09em;
      }

      .launch-architecture {
        margin-top: 24px;
        max-width: 340px;
        gap: 8px 10px;
      }

      .launch-architecture__dot {
        display: none;
      }

      .launch-date-label {
        font-size: 9px;
        letter-spacing: 0.14em;
      }

      .launch-language__summary {
        padding: 3px 7px;
      }

      .launch-language__menu {
        min-width: 176px;
        left: auto;
        right: 0;
        transform: none;
      }
    }
  </style>

  <SignupScripts />
</FlowLayout>
