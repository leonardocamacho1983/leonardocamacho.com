---
import { formatReadTime } from "@/lib/format";
import type { LaunchVariantProps } from "../types";

const {
  locale,
  variant,
  featured,
  coverlines,
  launchPath,
  archivePath,
  launchImage,
  copy,
} = Astro.props as LaunchVariantProps;

const sourceValue = `launch_home_${variant}`;
const featuredTitle = featured
  ? `${featured.title}${featured.titleEmphasis ? ` ${featured.titleEmphasis}` : ""}`
  : "";
const featuredRead = featured ? formatReadTime(featured.readTimeMinutes) : "";
const featuredCategory = featured?.category?.title || copy.featuredLabelFallback;
const featuredExcerpt = featured?.excerpt ? `${featured.excerpt.split(".")[0]}.` : "";
const launchPostPath = (slug: string) => `/${locale}/launch/archive/${slug}`;
const hasCoverlines = coverlines.length > 0;
---

<div class:list={["launch-v3", { "launch-v3--single": !hasCoverlines }]} data-launch-home data-variant={variant}>
  <div class="launch-v3__image-wrap">
    {launchImage ? <img src={launchImage} alt={featuredTitle} loading="eager" width="1800" height="1300" /> : null}
  </div>

  <div class="launch-v3__top-fade"></div>
  <div class="launch-v3__bottom-fade"></div>

  <header class:list={["launch-v3__top-strip", { "launch-v3__top-strip--single": !hasCoverlines }]}>
    <span class="launch-v3__mark">L</span>
    <span class="launch-v3__domain">{copy.domainLabel}</span>
  </header>

  <section class:list={["launch-v3__bottom", { "launch-v3__bottom--single": !hasCoverlines }]}>
    <article class:list={["launch-v3__article", { "launch-v3__article--single": !hasCoverlines }]}>
      <p>{featuredCategory}</p>
      {featured ? <a class="launch-v3__article-title" data-launch-article-link href={launchPostPath(featured.slug)}>{featuredTitle}</a> : null}
      <p>{featuredExcerpt}</p>
      {featured ? (
        <a class="launch-v3__article-read" data-launch-article-link href={launchPostPath(featured.slug)}>
          <span>{copy.readPrefix}</span>
          <span>-</span>
          <span>{featuredRead}</span>
        </a>
      ) : null}
    </article>

    <aside class:list={["launch-v3__subscribe", { "launch-v3__subscribe--single": !hasCoverlines }]}>
      <h1>
        {copy.titleLines.map((part, index) => (
          <>
            {index > 0 ? <br /> : null}
            {part.accent ? <em>{part.text}</em> : part.text}
          </>
        ))}
      </h1>
      <p>{copy.subtitle}</p>

      <form method="POST" action="/api/newsletter/subscribe" data-launch-form>
        <input type="hidden" name="locale" value={locale} />
        <input type="hidden" name="source" value={sourceValue} />
        <input type="hidden" name="variant" value={variant} />
        <input type="hidden" name="path" value={launchPath} />
        <input type="email" name="email" placeholder={copy.placeholder} required />
        <button type="submit">{copy.cta}</button>
      </form>

      <p>{copy.footerNote}</p>
      <a data-launch-latest-link href={archivePath}>{copy.secondaryLink}</a>
    </aside>
  </section>

</div>

<style>
  .launch-v3 {
    position: relative;
    width: 100vw;
    min-height: 100vh;
    min-height: 100svh;
    overflow: hidden;
    background: #1a1710;
  }

  .launch-v3__image-wrap {
    position: absolute;
    inset: 0;
  }

  .launch-v3__image-wrap img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center 28%;
    filter: brightness(0.78) saturate(0.95);
  }

  .launch-v3__top-fade,
  .launch-v3__bottom-fade {
    position: absolute;
    inset: 0;
    pointer-events: none;
    z-index: 2;
  }

  .launch-v3__top-fade {
    background: linear-gradient(to bottom, rgba(15, 9, 5, 0.82) 0%, rgba(15, 9, 5, 0) 18%);
  }

  .launch-v3--single .launch-v3__top-fade {
    background: linear-gradient(to bottom, rgba(15, 9, 5, 0.68) 0%, rgba(15, 9, 5, 0) 16%);
  }

  .launch-v3__bottom-fade {
    background: linear-gradient(
      to top,
      rgba(12, 7, 4, 1) 0%,
      rgba(12, 7, 4, 0.97) 14%,
      rgba(12, 7, 4, 0.93) 26%,
      rgba(12, 7, 4, 0.82) 38%,
      rgba(12, 7, 4, 0.56) 50%,
      rgba(12, 7, 4, 0.22) 62%,
      rgba(12, 7, 4, 0) 68%
    );
  }

  .launch-v3--single .launch-v3__bottom-fade {
    background: linear-gradient(
      to top,
      rgba(12, 7, 4, 0.96) 0%,
      rgba(12, 7, 4, 0.88) 18%,
      rgba(12, 7, 4, 0.64) 36%,
      rgba(12, 7, 4, 0.26) 54%,
      rgba(12, 7, 4, 0) 66%
    );
  }

  .launch-v3__top-strip {
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: clamp(14px, 2.2vh, 26px) clamp(20px, 3vw, 48px);
    border-bottom: 1px solid rgba(246, 243, 236, 0.09);
    z-index: 10;
  }

  .launch-v3__top-strip--single {
    border-bottom-color: rgba(246, 243, 236, 0.06);
  }

  .launch-v3__mark {
    font-family: "Playfair Display", Georgia, serif;
    font-size: clamp(20px, 2.2vw, 28px);
    color: #fff;
    line-height: 1;
  }

  .launch-v3__domain {
    font-family: "DM Sans", Arial, sans-serif;
    font-size: 10px;
    letter-spacing: 0.24em;
    text-transform: uppercase;
    color: rgba(246, 243, 236, 0.72);
    margin-inline: auto;
    pointer-events: none;
  }

  .launch-v3__bottom {
    position: absolute;
    left: 0;
    right: 0;
    bottom: 0;
    display: flex;
    z-index: 10;
  }

  .launch-v3__bottom--single {
    align-items: flex-end;
  }

  .launch-v3__article {
    flex: 1;
    padding: clamp(20px, 2.8vh, 40px) clamp(20px, 3vw, 48px);
    border-top: 1px solid rgba(246, 243, 236, 0.09);
    border-right: 1px solid rgba(246, 243, 236, 0.09);
  }

  .launch-v3__article--single {
    padding: clamp(26px, 3.4vh, 46px) clamp(26px, 3.6vw, 54px);
    border-top-color: rgba(246, 243, 236, 0.06);
    border-right-color: rgba(246, 243, 236, 0.06);
  }

  .launch-v3__article > p:first-child {
    font-family: "DM Sans", Arial, sans-serif;
    font-size: 9px;
    letter-spacing: 0.34em;
    text-transform: uppercase;
    color: #c47a85;
    margin-bottom: 14px;
  }

  .launch-v3__article-title {
    display: block;
    text-decoration: none;
    color: #fff;
    font-family: "Playfair Display", Georgia, serif;
    font-size: clamp(32px, 4.4vw, 72px);
    line-height: 1.02;
    letter-spacing: -0.022em;
    margin-bottom: 12px;
    max-width: 720px;
    text-shadow: 0 0 0 rgba(255, 255, 255, 0);
    transition:
      color 0.32s ease,
      text-shadow 0.42s ease,
      transform 0.42s cubic-bezier(0.22, 1, 0.36, 1);
  }

  .launch-v3__article--single .launch-v3__article-title {
    font-size: clamp(42px, 5vw, 80px);
    line-height: 0.98;
    max-width: 760px;
  }

  .launch-v3__article-title:hover,
  .launch-v3__article-title:focus-visible {
    color: #fff7f3;
    text-shadow:
      0 10px 28px rgba(0, 0, 0, 0.24),
      0 0 18px rgba(255, 244, 238, 0.16);
    transform: translateY(-2px);
  }

  .launch-v3__article-title:focus-visible {
    outline: 2px solid rgba(246, 243, 236, 0.76);
    outline-offset: 6px;
  }

  .launch-v3__article > p:nth-of-type(2) {
    font-family: "DM Sans", Arial, sans-serif;
    font-size: clamp(12px, 0.9vw, 14px);
    line-height: 1.72;
    color: rgba(246, 243, 236, 0.82);
    margin-bottom: 16px;
    max-width: 460px;
  }

  .launch-v3__article--single > p:nth-of-type(2) {
    font-size: clamp(13px, 1vw, 15px);
    line-height: 1.68;
    max-width: 520px;
    color: rgba(246, 243, 236, 0.78);
  }

  .launch-v3__article-read {
    display: inline-flex;
    gap: 8px;
    align-items: center;
    text-decoration: none;
    color: rgba(246, 243, 236, 0.52);
    font-family: "DM Sans", Arial, sans-serif;
    font-size: 9px;
    letter-spacing: 0.28em;
    text-transform: uppercase;
  }

  .launch-v3__subscribe {
    width: 38%;
    min-width: 360px;
    padding: clamp(20px, 2.8vh, 40px) clamp(20px, 3vw, 48px);
    border-top: 1px solid rgba(246, 243, 236, 0.09);
  }

  .launch-v3__subscribe--single {
    width: 34%;
    min-width: 340px;
    padding: clamp(18px, 2.4vh, 34px) clamp(22px, 2.8vw, 40px);
    border-top-color: rgba(246, 243, 236, 0.06);
    background: rgba(12, 7, 4, 0.22);
  }

  .launch-v3__subscribe h1 {
    margin: clamp(18px, 2.6vh, 30px) 0 14px;
    font-family: "Playfair Display", Georgia, serif;
    font-size: clamp(22px, 2.4vw, 42px);
    line-height: 1.08;
    letter-spacing: -0.022em;
    color: #fff;
  }

  .launch-v3__subscribe--single h1 {
    margin-top: 10px;
    font-size: clamp(20px, 2.1vw, 34px);
    line-height: 1.1;
  }

  .launch-v3__subscribe h1 em {
    color: #c47a85;
    font-style: italic;
  }

  .launch-v3__subscribe > p {
    font-family: "DM Sans", Arial, sans-serif;
    font-size: 13px;
    line-height: 1.6;
    color: rgba(246, 243, 236, 0.82);
    margin-bottom: 16px;
  }

  .launch-v3__subscribe--single > p {
    font-size: 12px;
    line-height: 1.58;
    color: rgba(246, 243, 236, 0.74);
  }

  .launch-v3__subscribe form {
    display: flex;
    border: 1px solid rgba(246, 243, 236, 0.48);
    background: rgba(12, 7, 4, 0.62);
    overflow: hidden;
    margin-bottom: 10px;
  }

  .launch-v3__subscribe--single form {
    background: rgba(12, 7, 4, 0.46);
    border-color: rgba(246, 243, 236, 0.34);
  }

  .launch-v3__subscribe input {
    flex: 1;
    min-width: 0;
    border: none;
    background: transparent;
    padding: 0 14px;
    height: 54px;
    font-family: "DM Sans", Arial, sans-serif;
    font-size: 14px;
    color: #f6f3ec;
    outline: none;
  }

  .launch-v3__subscribe input::placeholder {
    color: rgba(246, 243, 236, 0.62);
  }

  .launch-v3__subscribe button {
    border: none;
    background: #6e2535;
    color: #f6f3ec;
    height: 54px;
    padding: 0 26px;
    font-family: "DM Sans", Arial, sans-serif;
    font-size: 9px;
    font-weight: 700;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    cursor: pointer;
  }

  .launch-v3__subscribe--single button {
    padding: 0 22px;
    background: #783043;
  }

  .launch-v3__subscribe > p:nth-of-type(2) {
    font-size: 11px;
    color: rgba(246, 243, 236, 0.5);
    margin-bottom: 14px;
  }

  .launch-v3__subscribe--single > p:nth-of-type(2) {
    color: rgba(246, 243, 236, 0.44);
    margin-bottom: 12px;
  }

  .launch-v3__subscribe > a {
    display: inline-flex;
    text-decoration: none;
    color: rgba(246, 243, 236, 0.5);
    font-family: "DM Sans", Arial, sans-serif;
    font-size: 11px;
    border-bottom: 1px solid transparent;
    padding-bottom: 1px;
  }

  .launch-v3__subscribe--single > a {
    font-size: 10px;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .launch-v3__subscribe > a:hover {
    color: rgba(246, 243, 236, 0.82);
    border-bottom-color: rgba(246, 243, 236, 0.3);
  }

  @media (max-width: 960px) {
    .launch-v3__bottom {
      flex-direction: column;
    }

    .launch-v3__subscribe {
      width: 100%;
      min-width: 0;
      order: 1;
      padding-top: 18px;
      padding-bottom: 18px;
    }

    .launch-v3__article {
      order: 2;
    }

    .launch-v3__article-title {
      font-size: clamp(26px, 8vw, 48px);
      max-width: 560px;
    }

    .launch-v3__article > p:nth-of-type(2) {
      display: none;
    }

    .launch-v3__subscribe h1 {
      margin-top: 0;
      font-size: clamp(30px, 8vw, 44px);
    }
  }
</style>
