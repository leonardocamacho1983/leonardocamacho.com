---
export const prerender = false;
import FlowLayout from '../../layouts/FlowLayout.astro';
import { copy } from '../../data/newsletter-copy';
import {
  createSubscriberUpdateToken,
  hasNewsletterStateTokenSecret,
} from '../../lib/newsletter/state-token';

const c = copy['fr'];
const subscriberId = Astro.url.searchParams.get('ck_subscriber_id')?.trim() || '';
const updateToken =
  subscriberId && hasNewsletterStateTokenSecret()
    ? createSubscriberUpdateToken({ subscriberId, ttlMs: 1000 * 60 * 45 })
    : '';
const profileSaveWarningMissingToken =
  "Nous n'avons pas pu enregistrer votre profil de manière sécurisée dans cette session.";
const profileSaveWarningSaveFailed =
  "Vos réponses n'ont pas été enregistrées cette fois, mais votre accès est confirmé.";
---

<FlowLayout title="Confirmé — Leonardo Camacho" description="Vous êtes dans la salle." lang={c.lang}>
  <main class="flow-container">
    <div class="flow-layer confirmed-enter">
      <h1 class="flow-hero-split">{c.confirmedHero1} <em>{c.confirmedHero2}</em></h1>
      <div class="confirmed-gap-md"></div>
      <p class="flow-body" set:html={c.confirmedSeason} />
      <div class="confirmed-gap-lg"></div>
      <h2 class="flow-heading-2">{c.confirmedFormTitle}</h2>
      <p class="flow-body">{c.confirmedFormSubtitle}</p>
      <p class="flow-body flow-muted">{c.confirmedFormNote}</p>

      <form
        class="flow-form"
        id="profileForm"
        data-subscriber-id={subscriberId}
        data-update-token={updateToken}
        data-warning-missing-token={profileSaveWarningMissingToken}
        data-warning-save-failed={profileSaveWarningSaveFailed}
      >
        <div class="flow-field">
          <label class="flow-field-label-caps" for="position">{c.confirmedLabelPosition}</label>
          <input type="text" id="position" name="position" placeholder={c.confirmedPlaceholderPosition} class="flow-input" />
        </div>
        <div class="flow-field">
          <label class="flow-field-label-caps" for="company">{c.confirmedLabelCompany}</label>
          <input type="text" id="company" name="company" placeholder={c.confirmedPlaceholderCompany} class="flow-input" />
        </div>
        <div class="flow-field">
          <label class="flow-field-label" for="company_website">{c.confirmedLabelCompanyWebsite}</label>
          <input type="url" id="company_website" name="company_website" placeholder={c.confirmedPlaceholderCompanyWebsite} class="flow-input" inputmode="url" />
        </div>
        <div class="flow-field">
          <label class="flow-field-label" for="team_size">{c.confirmedLabelTeamSize}</label>
          <input type="text" id="team_size" name="team_size" placeholder={c.confirmedPlaceholderTeamSize} class="flow-input" />
        </div>
        <div class="flow-field">
          <label class="flow-field-label" for="strategic_question">
            {c.confirmedLabelQuestion}
            <span class="flow-optional">{c.confirmedOptional}</span>
          </label>
          <textarea id="strategic_question" name="strategic_question" placeholder={c.confirmedPlaceholderQuestion} class="flow-textarea" rows="3"></textarea>
        </div>
        <div class="flow-form-actions">
          <button type="submit" class="flow-btn-submit">{c.confirmedSubmit}</button>
          <button type="button" id="skipProfile" class="flow-skip">{c.confirmedSkip}</button>
        </div>
        <p id="profileSaveWarning" class="profile-save-warning" aria-live="polite"></p>
      </form>

      <section id="postSubmit" class="flow-post-submit">
        <div class="confirmed-gap-xl"></div>
        <p class="flow-body-italic">{c.confirmedRevealTitle}</p>
        <div class="flow-reveal-list">
          <div class="flow-reveal-item"><p>{c.confirmedRevealPoint1}</p></div>
          <div class="flow-reveal-item"><p>{c.confirmedRevealPoint2}</p></div>
          <div class="flow-reveal-item"><p>{c.confirmedRevealPoint3}</p></div>
        </div>
        <p class="flow-body-italic confirmed-tagline">{c.confirmedRevealTagline}</p>

        <div class="flow-social-links">
          <a href="https://www.linkedin.com/in/leocamacho/" target="_blank" rel="noopener noreferrer" class="flow-social-link">{c.confirmedRevealLinkedin}</a>
        </div>
      </section>
    </div>
  </main>
  <div class="flow-bottom-thread" aria-hidden="true"></div>

  <script>
    const form = document.getElementById('profileForm') as HTMLFormElement | null;
    const skip = document.getElementById('skipProfile') as HTMLButtonElement | null;
    const reveal = document.getElementById('postSubmit') as HTMLElement | null;
    const saveWarning = document.getElementById('profileSaveWarning') as HTMLParagraphElement | null;
    const warningMissingToken = form?.dataset.warningMissingToken || '';
    const warningSaveFailed = form?.dataset.warningSaveFailed || '';

    const showPostSubmit = () => {
      form?.classList.add('is-hidden');
      reveal?.classList.add('is-visible');
    };

    const setSaveWarning = (message: string) => {
      if (!saveWarning) return;
      saveWarning.textContent = message;
      saveWarning.classList.add('is-visible');
    };

    const clearSaveWarning = () => {
      if (!saveWarning) return;
      saveWarning.textContent = '';
      saveWarning.classList.remove('is-visible');
    };

    form?.addEventListener('submit', async (e) => {
      e.preventDefault();
      clearSaveWarning();

      const subscriberId = form?.dataset.subscriberId?.trim() || '';
      const updateToken = form?.dataset.updateToken?.trim() || '';
      const submitButton = form?.querySelector('button[type="submit"]') as HTMLButtonElement | null;

      const fields = {
        position: (document.getElementById('position') as HTMLInputElement).value,
        company: (document.getElementById('company') as HTMLInputElement).value,
        company_website: (document.getElementById('company_website') as HTMLInputElement).value,
        team_size: (document.getElementById('team_size') as HTMLInputElement).value,
        strategic_question: (document.getElementById('strategic_question') as HTMLTextAreaElement).value,
      };

      if (submitButton) submitButton.disabled = true;

      try {
        if (subscriberId) {
          if (!updateToken) {
            setSaveWarning(warningMissingToken);
          } else {
            try {
              const response = await fetch('/api/update-subscriber', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ subscriber_id: subscriberId, update_token: updateToken, fields }),
              });

              if (!response.ok) {
                setSaveWarning(warningSaveFailed);
              }
            } catch {
              setSaveWarning(warningSaveFailed);
            }
          }
        }
      } finally {
        if (submitButton) submitButton.disabled = false;
        showPostSubmit();
      }
    });

    skip?.addEventListener('click', () => {
      clearSaveWarning();
      showPostSubmit();
    });
  </script>

  <style>
    .confirmed-enter {
      animation: confirmed-fade-up 0.8s ease-out both;
    }

    .confirmed-gap-md { height: 40px; }
    .confirmed-gap-lg { height: 48px; }
    .confirmed-gap-xl { height: 40px; }

    .confirmed-tagline {
      margin-top: 28px;
      margin-bottom: 24px;
    }

    .profile-save-warning {
      display: none;
      margin-top: 12px;
      color: #875b2a;
      font-size: 0.86rem;
      line-height: 1.45;
    }

    .profile-save-warning.is-visible {
      display: block;
    }

    @keyframes confirmed-fade-up {
      from { opacity: 0; transform: translateY(12px); }
      to { opacity: 1; transform: translateY(0); }
    }
  </style>
</FlowLayout>
