---
export const prerender = false;

import FlowLayout from "@/layouts/FlowLayout.astro";
import BaseLayout from "@/layouts/BaseLayout.astro";
import { getHomePage, getPosts, getSiteSettings } from "@/lib/sanity/api";
import { urlFor } from "@/lib/sanity/image";
import { formatMonthYear } from "@/lib/format";
import { categoryLabel, categoryToneClass } from "@/lib/category-style";
import { LOCALES, localizedPath } from "@/lib/locales";
import { getLocaleOrDefault, isPreviewRequest, localeLinksForPath } from "@/lib/page-helpers";
import heroBannerAsset from "@/assets/048ace4054b2f01d8084592b379bf586ce2ee426.png";
import { copy as newsletterCopy } from "@/data/newsletter-copy";
import EditorialIllustration from "@/components/launch/EditorialIllustration.astro";
import SignupScripts from "@/components/newsletter/SignupScripts.astro";

const isLaunchMode = import.meta.env.PUBLIC_LAUNCH_MODE === 'true';

const rawLocale = Astro.params.locale;
const locale = getLocaleOrDefault(rawLocale);
if (!rawLocale || rawLocale.toLowerCase() !== locale) {
  return Astro.redirect(localizedPath("en-us", "home"), 302);
}

// --- Newsletter locale mappings ---
const COPY_KEY: Record<string, string> = {
  'en-us': 'en', 'en-gb': 'en',
  'pt-br': 'pt-br', 'pt-pt': 'pt', 'fr-fr': 'fr',
};
const WELCOME_PATH: Record<string, string> = {
  'en-us': '/welcome', 'en-gb': '/welcome',
  'pt-br': '/pt-br/welcome', 'pt-pt': '/pt/welcome', 'fr-fr': '/fr/welcome',
};
const KIT_LOCALE: Record<string, string> = {
  'en-us': 'en_US', 'en-gb': 'en_UK',
  'pt-br': 'pt_BR', 'pt-pt': 'pt_PT', 'fr-fr': 'fr_FR',
};

const nc = newsletterCopy[COPY_KEY[locale] || 'en'];
const kitLocale = KIT_LOCALE[locale] || 'en_US';
const welcomePath = WELCOME_PATH[locale] || '/welcome';
const [headlineLine1, headlineLine2 = ''] = nc.headline.split('\n');
const currentLocaleMeta = LOCALES.find((item) => item.key === locale) || LOCALES[0];
const launchRevealDelayMs = Number(import.meta.env.PUBLIC_LAUNCH_REVEAL_DELAY_MS || 1400);

// --- Shared ---
const pathname = new URL(Astro.request.url).pathname;
const isPreview = isPreviewRequest(Astro.cookies);

// --- Normal mode: fetch Sanity data ---
const [settings, home, posts] = isLaunchMode
  ? ([null, null, []] as const)
  : await Promise.all([
      getSiteSettings(locale, isPreview),
      getHomePage(locale, isPreview),
      getPosts(locale, isPreview),
    ]);

const localeLinks = isLaunchMode ? [] : localeLinksForPath(pathname, locale);
const privacyUrl = isLaunchMode ? '' : localizedPath(locale, "privacy");

// Derived data for normal mode (computed with safe guards)
const mainPost = home ? (home.featuredMainPost || posts[0] || null) : null;
const insightPost = home ? (home.featuredInsightPost || posts[1] || null) : null;
const recentPosts = home
  ? (home.featuredRecentPosts?.length
      ? home.featuredRecentPosts
      : (posts as any[]).filter((p: any) => p.id !== mainPost?.id && p.id !== insightPost?.id).slice(0, 2))
  : [];
const featuredMainExcerpt = mainPost?.excerpt?.match(/^.*?[.!?](?:\s|$)/)?.[0]?.trim() || mainPost?.excerpt || "";

const heroImage = home?.heroImage
  ? urlFor(home.heroImage).width(1200).height(980).fit("crop").url()
  : heroBannerAsset.src;
const mainImage = mainPost?.coverImage
  ? urlFor(mainPost.coverImage).width(900).height(760).fit("crop").url()
  : "https://images.unsplash.com/photo-1612572357378-f8da682e6e3a?auto=format&fit=crop&w=900&q=80";
const textureImage = home?.stayUpdatedTexture
  ? urlFor(home.stayUpdatedTexture).width(1400).height(600).fit("crop").url()
  : "https://images.unsplash.com/photo-1706271952285-01b5e3fc2d78?auto=format&fit=crop&w=1400&q=80";

const aboutHeadlineMatch = home?.aboutHeadline?.match(/outlast their competition/i);
const aboutHeadlinePrefix = aboutHeadlineMatch
  ? home!.aboutHeadline.slice(0, aboutHeadlineMatch.index)
  : (home?.aboutHeadline || '');
const aboutHeadlineEmphasis = aboutHeadlineMatch ? aboutHeadlineMatch[0] : "";
const aboutHeadlineSuffix = aboutHeadlineMatch
  ? home!.aboutHeadline.slice((aboutHeadlineMatch.index || 0) + aboutHeadlineMatch[0].length)
  : "";
---

{isLaunchMode ? (
  <FlowLayout
    title={`Leonardo Camacho — ${nc.headlineAccent}`}
    description={nc.supportingNote}
    lang={nc.lang}
    robots="index,follow"
  >
    <div class="launch-page">
      <EditorialIllustration />

      <main class="launch-main">
        <section class="launch-content">
          <div class="launch-author">
            <span class="launch-author__line"></span>
            <span class="launch-author__name">Leonardo Camacho</span>
            <span class="launch-author__line"></span>
          </div>

          <h1 class="launch-headline">
            {headlineLine1}{headlineLine2 !== undefined && <br />}{headlineLine2}<em>{nc.headlineAccent}</em>
          </h1>

          <p class="launch-subhead">
            {nc.subhead1}<br />{nc.subhead2}
          </p>

          <div id="launchFormWrap" class="launch-form-wrap">
            <form
              class="launch-form"
              id="launchSignupForm"
              data-kit-locale={kitLocale}
              data-welcome-path={welcomePath}
              data-reveal-delay-ms={launchRevealDelayMs}
            >
              <input
                class="launch-input"
                type="email"
                name="email"
                required
                placeholder="your@email.com"
                autocomplete="email"
              />
              <button class="launch-submit" type="submit">{nc.ctaButton}</button>
            </form>
            <p class="launch-error" id="launchError" aria-live="polite"></p>
            <p class="launch-note">{nc.supportingNote}</p>
          </div>

          <div id="launchSuccess" class="launch-success" aria-live="polite">
            <div class="launch-success__badge">
              <svg width="12" height="12" viewBox="0 0 14 14" fill="none" aria-hidden="true">
                <path d="M3 7L6 10.5L11 4" stroke="white" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"></path>
              </svg>
            </div>
            <p class="launch-success__title">{nc.launchSuccessTitle}</p>
            <p class="launch-success__body">{nc.launchSuccessBody}</p>
          </div>

          <div class="launch-architecture" aria-label="What you'll receive">
            <span>{nc.navWriting}</span>
            <span class="launch-architecture__dot">◆</span>
            <span>{nc.navResearch}</span>
            <span class="launch-architecture__dot">◆</span>
            <span class="launch-architecture__accent">{nc.navLetter}</span>
            <span class="launch-architecture__dot">◆</span>
            <span>{nc.navStrategy}</span>
          </div>

          <div class="launch-meta">
            <span class="launch-date-label">{nc.launchDate}</span>
            <span class="launch-meta__dot">•</span>
            <details class="launch-language">
              <summary class="launch-language__summary" aria-label="Language selector">
                <span class="launch-language__flag">{currentLocaleMeta.flag}</span>
                <span class="launch-language__region">{currentLocaleMeta.key.split('-')[1].toUpperCase()}</span>
              </summary>
              <div class="launch-language__menu">
                {LOCALES.map((l) => (
                  <a
                    href={`/${l.key}`}
                    class={`launch-language__option${l.key === locale ? " launch-language__option--active" : ""}`}
                    aria-current={l.key === locale ? "true" : undefined}
                  >
                    <span>{l.flag}</span>
                    <span>{l.label}</span>
                  </a>
                ))}
              </div>
            </details>
          </div>
        </section>
      </main>

      <div class="launch-thread" aria-hidden="true"></div>
    </div>

    <style>
      .launch-page {
        position: relative;
        width: 100%;
        min-height: 100vh;
        min-height: 100svh;
        overflow: hidden;
        background: var(--flow-cream);
        isolation: isolate;
      }

      .launch-main {
        position: relative;
        z-index: 1;
        min-height: 100vh;
        min-height: 100svh;
        display: flex;
        align-items: center;
        justify-content: center;
        padding: 36px 24px 52px;
      }

      .launch-content {
        width: min(680px, 100%);
        max-width: 100%;
        text-align: center;
        position: relative;
        z-index: 1;
      }

      .launch-author {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        gap: 16px;
        margin-bottom: 52px;
      }

      .launch-author__line {
        width: 52px;
        height: 1px;
        background: var(--flow-border);
      }

      .launch-author__name {
        font-family: var(--flow-font-ui);
        font-size: 10px;
        font-weight: 500;
        letter-spacing: 0.28em;
        text-transform: uppercase;
        color: var(--flow-stone);
      }

      .launch-headline {
        margin: 0;
        font-family: var(--flow-font-display);
        font-size: clamp(34px, 6.4vw, 56px);
        line-height: 1.08;
        font-weight: 400;
        color: var(--flow-near-black);
        letter-spacing: -0.02em;
      }

      .launch-headline em {
        font-style: italic;
        color: var(--flow-red);
      }

      .launch-subhead {
        margin: 16px auto 0;
        max-width: 440px;
        font-family: var(--flow-font-body);
        font-size: clamp(14px, 2.1vw, 16px);
        line-height: 1.75;
        color: var(--flow-muted);
      }

      .launch-form-wrap {
        margin-top: 28px;
      }

      .launch-form-wrap.is-hidden {
        display: none;
      }

      .launch-form {
        display: flex;
        max-width: 460px;
        margin: 0 auto;
        border: 1px solid var(--flow-border);
        border-radius: 8px;
        overflow: hidden;
        background: #f7f3ee;
        box-shadow: 0 2px 12px rgba(42, 42, 42, 0.05);
      }

      .launch-input {
        flex: 1;
        min-width: 0;
        border: none;
        background: transparent;
        color: var(--flow-body);
        font-family: var(--flow-font-ui);
        font-size: 14px;
        padding: 14px 16px;
        outline: none;
      }

      .launch-input::placeholder {
        color: #b5aea6;
      }

      .launch-submit {
        border: none;
        background: var(--flow-red);
        color: #fff;
        font-family: var(--flow-font-ui);
        font-size: 11px;
        font-weight: 600;
        letter-spacing: 0.08em;
        text-transform: uppercase;
        white-space: nowrap;
        padding: 14px 18px;
        cursor: pointer;
        transition: opacity 0.2s ease;
      }

      .launch-submit:hover {
        opacity: 0.88;
      }

      .launch-submit:disabled {
        opacity: 0.6;
        cursor: not-allowed;
      }

      .launch-error {
        min-height: 20px;
        margin-top: 8px;
        font-family: var(--flow-font-ui);
        font-size: 12px;
        color: var(--flow-red);
      }

      .launch-note {
        margin-top: 2px;
        font-family: var(--flow-font-body);
        font-size: 12px;
        font-style: italic;
        color: var(--flow-stone);
      }

      .launch-success {
        display: none;
        margin-top: 30px;
      }

      .launch-success.is-visible {
        display: block;
      }

      .launch-success__badge {
        width: 24px;
        height: 24px;
        margin: 0 auto 10px;
        border-radius: 999px;
        background: #6b8f71;
        display: flex;
        align-items: center;
        justify-content: center;
      }

      .launch-success__title {
        margin: 0;
        font-family: var(--flow-font-display);
        font-size: 16px;
        font-style: italic;
        color: var(--flow-near-black);
      }

      .launch-success__body {
        margin: 6px 0 0;
        font-family: var(--flow-font-ui);
        font-size: 12px;
        color: var(--flow-stone);
      }

      .launch-architecture {
        margin-top: 30px;
        display: flex;
        gap: 12px;
        align-items: center;
        justify-content: center;
        flex-wrap: wrap;
        max-width: 440px;
        margin-inline: auto;
        font-family: var(--flow-font-ui);
        font-size: 11px;
        letter-spacing: 0.06em;
        color: var(--flow-stone);
      }

      .launch-architecture span {
        white-space: nowrap;
      }

      .launch-architecture__accent {
        color: var(--flow-red);
        font-family: var(--flow-font-display);
        font-style: italic;
        letter-spacing: 0.02em;
      }

      .launch-architecture__dot {
        color: #8a7e76;
        opacity: 0.6;
        font-size: 7px;
        transform: translateY(-1px);
      }

      .launch-meta {
        margin-top: 24px;
        display: inline-flex;
        align-items: center;
        gap: 10px;
        flex-wrap: wrap;
        justify-content: center;
      }

      .launch-date-label {
        font-family: var(--flow-font-ui);
        font-size: 10px;
        font-weight: 500;
        letter-spacing: 0.18em;
        text-transform: uppercase;
        color: var(--flow-stone);
      }

      .launch-meta__dot {
        color: var(--flow-stone);
        opacity: 0.45;
        font-size: 8px;
      }

      .launch-language {
        position: relative;
      }

      .launch-language[open] .launch-language__summary {
        background: rgba(232, 226, 218, 0.9);
      }

      .launch-language__summary {
        list-style: none;
        cursor: pointer;
        border-radius: 8px;
        padding: 4px 8px;
        display: inline-flex;
        align-items: center;
        gap: 6px;
      }

      .launch-language__summary::-webkit-details-marker {
        display: none;
      }

      .launch-language__flag {
        font-size: 13px;
        line-height: 1;
      }

      .launch-language__region {
        font-family: var(--flow-font-ui);
        font-size: 10px;
        letter-spacing: 0.08em;
        color: var(--flow-stone);
      }

      .launch-language__menu {
        position: absolute;
        left: 50%;
        transform: translateX(-50%);
        bottom: calc(100% + 8px);
        min-width: 220px;
        border-radius: 12px;
        border: 1px solid var(--flow-border);
        background: #f7f3ee;
        box-shadow: 0 12px 40px rgba(42, 42, 42, 0.14);
        padding: 6px 0;
      }

      .launch-language__option {
        display: flex;
        align-items: center;
        gap: 10px;
        padding: 8px 12px;
        text-decoration: none;
        color: var(--flow-body);
        font-family: var(--flow-font-ui);
        font-size: 13px;
      }

      .launch-language__option:hover {
        background: rgba(232, 226, 218, 0.65);
      }

      .launch-language__option--active {
        color: var(--flow-red);
        font-weight: 500;
      }

      .launch-thread {
        position: absolute;
        left: 0;
        right: 0;
        bottom: 0;
        height: 2px;
        background: var(--flow-red);
        z-index: 2;
      }

      @media (max-width: 760px) {
        .launch-main {
          padding: calc(26px + env(safe-area-inset-top)) 20px calc(42px + env(safe-area-inset-bottom));
          align-items: flex-start;
        }

        .launch-author {
          margin-bottom: 42px;
        }

        .launch-author__line {
          width: 40px;
        }

        .launch-form {
          flex-direction: column;
          max-width: 100%;
        }

        .launch-submit {
          width: 100%;
        }

        .launch-note {
          margin-top: 10px;
        }

        .launch-meta {
          margin-top: 22px;
        }
      }

      @media (max-width: 540px) {
        .launch-content {
          width: min(420px, 100%);
        }

        .launch-author {
          gap: 10px;
          margin-bottom: 34px;
        }

        .launch-author__line {
          width: 30px;
        }

        .launch-author__name {
          font-size: 9px;
          letter-spacing: 0.2em;
        }

        .launch-headline {
          font-size: clamp(28px, 11vw, 42px);
          line-height: 1.1;
        }

        .launch-subhead {
          margin-top: 14px;
          font-size: 13px;
          line-height: 1.65;
          max-width: 320px;
        }

        .launch-form-wrap {
          margin-top: 24px;
        }

        .launch-input {
          padding: 16px 18px;
          font-size: 16px;
        }

        .launch-submit {
          padding: 16px 18px;
          font-size: 12px;
          letter-spacing: 0.09em;
        }

        .launch-architecture {
          margin-top: 24px;
          max-width: 340px;
          gap: 8px 10px;
        }

        .launch-architecture__dot {
          display: none;
        }

        .launch-date-label {
          font-size: 9px;
          letter-spacing: 0.14em;
        }

        .launch-language__summary {
          padding: 3px 7px;
        }

        .launch-language__menu {
          min-width: 176px;
          left: auto;
          right: 0;
          transform: none;
        }
      }
    </style>

    <SignupScripts />
  </FlowLayout>
) : (
  <BaseLayout
    locale={locale}
    settings={settings!}
    localeLinks={localeLinks}
    title={`${settings!.siteTitle} | ${home!.heroTitle} ${home!.heroTitleEmphasis}`}
    description={home!.heroDescription}
    canonicalPath={`/${locale}`}
    isPreview={isPreview}
  >
    <section class="sec-hero">
      <div class="container">
        <article class="hero hero--print1 hero-entrance">
          <div class="hero__content pad-hero-card">
            <div class="eyebrow-row hero__eyebrow">
              <span class="eyebrow-line hero__eyebrow-line"></span>
              <span class="eyebrow-label hero__eyebrow-label">{home!.heroKicker}</span>
            </div>
            <h2 class="hero__title">
              {home!.heroTitle}
              <br />
              <em>{home!.heroTitleEmphasis}</em>
            </h2>
            <p class="hero__description">{home!.heroDescription}</p>
            <a class="link-arrow arrow-link hero__cta" href={home!.heroCtaPost?.slug ? localizedPath(locale, "post", home!.heroCtaPost.slug) : localizedPath(locale, "writing")}>
              <span>{home!.heroCtaLabel}</span>
              <span class="arrow" aria-hidden="true">→</span>
            </a>
          </div>
          <div class="hero__media">
            <img class="ken-burns-hero" src={heroImage} alt={settings!.siteTitle} loading="eager" width="1200" height="980" />
          </div>
          <span class="hero__location hero__location--overlay">{home!.heroLocationLabel || "Florianópolis, Brazil"}</span>
        </article>
      </div>
    </section>

    <section class="sec-header">
      <div class="container credibility scroll-reveal" data-y="24" data-delay="40">
        <p class="credibility__label">{home!.credibilityLabel}</p>
        <div class="credibility__items">
          {home!.credibilityItems.map((item: any, index: number) => (
            <>
              {index > 0 ? <span class="credibility__divider"></span> : null}
              <span>{item.name}</span>
            </>
          ))}
        </div>
      </div>
    </section>

    <section class="sec-featured">
      <div class="container">
        <div class="section-line"></div>
        <div class="section-head scroll-reveal" data-y="24" data-delay="80">
          <h3 class="section-title">{home!.featuredSectionTitle}</h3>
          <a class="link-arrow arrow-link" href={localizedPath(locale, "writing")}>
            <span>{home!.featuredViewAllLabel}</span>
            <span class="arrow" aria-hidden="true">→</span>
          </a>
        </div>

        <div class="featured-grid gap-featured-main">
          {mainPost ? (
            <article class="card featured-main scroll-reveal" data-y="30" data-delay="120">
              <div class="featured-main__text pad-featured-card">
                <span class={`tag ${categoryToneClass(mainPost.category?.slug)}`}>{categoryLabel(mainPost.category)}</span>
                <h4 class="post-title">
                  {mainPost.title}
                  {mainPost.titleEmphasis ? <><br /><em>{mainPost.titleEmphasis}</em></> : null}
                </h4>
                <p class="post-excerpt">{featuredMainExcerpt}</p>
                <div class="featured-main__cta">
                  <a class="link-arrow arrow-link" href={localizedPath(locale, "post", mainPost.slug)}>
                    <span>Read Essay</span>
                    <span class="arrow" aria-hidden="true">→</span>
                  </a>
                </div>
              </div>
              <a class="featured-main__media" href={localizedPath(locale, "post", mainPost.slug)}>
                <img src={mainImage} alt={mainPost.title} width="900" height="760" />
              </a>
            </article>
          ) : null}

          <div class="featured-side">
            {insightPost ? (
              <article class="card pad-featured-card featured-side__insight scroll-reveal" data-y="30" data-delay="180">
                <span class={`tag ${categoryToneClass(insightPost.category?.slug)}`}>{categoryLabel(insightPost.category)}</span>
                <div class="featured-side__insight-head">
                  <h4 class="post-title">
                    {insightPost.title}
                    {insightPost.titleEmphasis ? <><br /><em>{insightPost.titleEmphasis}</em></> : null}
                  </h4>
                  <span class="featured-side__insight-date">{formatMonthYear(insightPost.publishedAt, locale)}</span>
                </div>
                <span class="featured-side__insight-meta">{formatMonthYear(insightPost.publishedAt, locale)}</span>
              </article>
            ) : null}

            <article class="card pad-featured-card featured-side__recent scroll-reveal" data-y="30" data-delay="220">
              <span class="eyebrow-label eyebrow-label--accent">{home!.featuredRecentPostsLabel}</span>
              <ul class="featured-list">
                {recentPosts.map((post: any) => (
                  <li>
                    <a href={localizedPath(locale, "post", post.slug)} class="post-title featured-list__link">
                      {post.title} {post.titleEmphasis ? <em>{post.titleEmphasis}</em> : null}
                    </a>
                    <span class="featured-list__date">{formatMonthYear(post.publishedAt, locale)}</span>
                  </li>
                ))}
              </ul>
            </article>
          </div>
        </div>
      </div>
    </section>

    <section class="sec-about-teaser">
      <div class="container">
        <article class="about-teaser scroll-reveal" data-y="28" data-delay="80">
          <div class="accent-column" aria-hidden="true">
            <span class="accent-column__line"></span>
            <span class="accent-column__dot"></span>
          </div>
          <div>
            <div class="eyebrow-row">
              <span class="eyebrow-label eyebrow-label--accent">{home!.aboutKicker}</span>
            </div>
            <p class="about-teaser__headline">
              {aboutHeadlineMatch ? (
                <>
                  {aboutHeadlinePrefix}
                  <em>{aboutHeadlineEmphasis}</em>
                  {aboutHeadlineSuffix}
                </>
              ) : (
                home!.aboutHeadline
              )}
            </p>
            <p class="about-teaser__body">{home!.aboutBody}</p>
            <a class="link-arrow arrow-link" href={localizedPath(locale, "about")}>
              <span>{home!.aboutCtaLabel}</span>
              <span class="arrow" aria-hidden="true">→</span>
            </a>
          </div>
        </article>
        <div class="section-line"></div>
      </div>
    </section>

    <section class="sec-stay-updated">
      <div class="container">
        <article class="newsletter scroll-reveal" data-y="28" data-delay="100">
          <img class="newsletter__texture" src={textureImage} alt="" aria-hidden="true" width="1400" height="600" />
          <div class="newsletter__overlay"></div>
          <div class="newsletter__content pad-stay-updated-inner">
            <h3 class="newsletter__title">{home!.stayUpdatedTitle}</h3>
            <p class="newsletter__copy">{home!.stayUpdatedDescription}</p>
            <form
              class="newsletter__form"
              id="signupForm"
              method="POST"
              action="/api/newsletter/subscribe"
            >
              <input type="hidden" name="locale" value={locale} />
              <input type="hidden" name="source" value="home" />
              <input type="hidden" name="path" value={pathname} />
              <input class="newsletter__input" type="email" name="email" required placeholder={home!.stayUpdatedPlaceholder} />
              <button class="newsletter__submit" type="submit">{home!.stayUpdatedButtonLabel}</button>
            </form>
            <p class="newsletter__consent-note">
              By subscribing I agree to receive the newsletter and accept the{" "}
              <a href={privacyUrl}>privacy policy</a>.
            </p>
          </div>
        </article>
      </div>
    </section>

    <SignupScripts />
  </BaseLayout>
)}
