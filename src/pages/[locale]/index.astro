---
export const prerender = false;

import { getLocaleOrDefault, isPreviewRequest } from "@/lib/page-helpers";

const isLaunchMode = import.meta.env.PUBLIC_LAUNCH_MODE === "true";
const HomeView: any = (await import("@/components/home/EditorialHome.astro")).default;

const rawLocale = Astro.params.locale;
const locale = getLocaleOrDefault(rawLocale);
if (!rawLocale || rawLocale.toLowerCase() !== locale) {
  return Astro.redirect("/en-us", 302);
}

if (isLaunchMode) {
  return Astro.redirect(`/${locale}/launch`, 302);
}

const pathname = new URL(Astro.request.url).pathname;
const isPreview = isPreviewRequest(Astro.cookies);
---

<HomeView locale={locale} pathname={pathname} isPreview={isPreview} />
