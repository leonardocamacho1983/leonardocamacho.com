---
export const prerender = false;

import { PortableText } from "astro-portabletext";
import BaseLayout from "@/layouts/BaseLayout.astro";
import FlagshipDiagramBlock from "@/components/writing/FlagshipDiagramBlock.astro";
import FlagshipEpigraph from "@/components/writing/FlagshipEpigraph.astro";
import FlagshipHeadingBlock from "@/components/writing/FlagshipHeadingBlock.astro";
import FlagshipProseBlock from "@/components/writing/FlagshipProseBlock.astro";
import FlagshipPullQuote from "@/components/writing/FlagshipPullQuote.astro";
import { formatMonthYear, formatReadTime } from "@/lib/format";
import { transformFlagshipBody } from "@/lib/flagship-body";
import { mapHtmlLang } from "@/lib/format";
import { categoryLabel, categoryToneClass } from "@/lib/category-style";
import { localizedPath, type LocaleKey } from "@/lib/locales";
import { getLocaleOrDefault, isPreviewRequest, localeLinksForPath } from "@/lib/page-helpers";
import { getPostBySlug, getPosts, getSiteSettings } from "@/lib/sanity/api";
import { urlFor } from "@/lib/sanity/image";
import { absoluteUrl } from "@/lib/seo";

const rawLocale = Astro.params.locale;
const locale = getLocaleOrDefault(rawLocale);
const slug = Astro.params.slug || "";
if (!rawLocale || rawLocale.toLowerCase() !== locale) {
  return Astro.redirect(localizedPath("en-us", "home"), 302);
}

const isPreview = isPreviewRequest(Astro.cookies);
const [settings, post, posts] = await Promise.all([
  getSiteSettings(locale, isPreview),
  getPostBySlug(locale, slug, isPreview),
  getPosts(locale, isPreview),
]);

if (!post) {
  return Astro.redirect(localizedPath(locale, "writing"), 302);
}

const pathname = new URL(Astro.request.url).pathname;
const translations = (post.translations || []).filter(
  (item): item is { locale: LocaleKey; slug: string } => Boolean(item.locale && item.slug),
);
const localeLinks = localeLinksForPath(pathname, locale, translations);

const heroImage = post.coverImage
  ? urlFor(post.coverImage).width(1600).height(860).fit("crop").url()
  : "https://images.unsplash.com/photo-1473448912268-2022ce9509d8?auto=format&fit=crop&w=1600&q=80";

const seoTitle = post.seoTitle || `${post.title} ${post.titleEmphasis || ""} | ${settings.siteTitle}`;
const seoDescription = post.seoDescription || post.excerpt;
const headline = `${post.title}${post.titleEmphasis ? ` ${post.titleEmphasis}` : ""}`.trim();
const canonicalPath = `/${locale}/writing/${post.slug}`;
const canonicalUrl = absoluteUrl(canonicalPath, Astro.url, Astro.request.headers);
const homeUrl = absoluteUrl(`/${locale}`, Astro.url, Astro.request.headers);
const websiteId = `${absoluteUrl("/", Astro.url, Astro.request.headers)}#website`;
const articleOgImage = absoluteUrl(
  `/og/article/${post.slug}.png?${new URLSearchParams({ locale }).toString()}`,
  Astro.url,
  Astro.request.headers,
);
const relatedPosts = posts
  .filter((candidate) => candidate.slug !== post.slug)
  .filter((candidate) => candidate.category?.slug === post.category?.slug)
  .slice(0, 3);
const articleSchema = {
  "@context": "https://schema.org",
  "@type": "BlogPosting",
  "@id": `${canonicalUrl}#article`,
  url: canonicalUrl,
  headline,
  description: seoDescription,
  inLanguage: mapHtmlLang(locale),
  datePublished: post.publishedAt,
  dateModified: post.updatedAt || post.publishedAt,
  author: {
    "@type": "Person",
    name: settings.siteTitle,
    url: homeUrl,
  },
  publisher: {
    "@type": "Organization",
    name: settings.siteTitle,
    url: homeUrl,
  },
  image: {
    "@type": "ImageObject",
    url: articleOgImage,
    width: 1200,
    height: 630,
  },
  articleSection: categoryLabel(post.category),
  isPartOf: {
    "@type": "WebSite",
    "@id": websiteId,
  },
  mainEntityOfPage: {
    "@type": "WebPage",
    "@id": canonicalUrl,
  },
};
const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  itemListElement: [
    {
      "@type": "ListItem",
      position: 1,
      name: settings.siteTitle,
      item: absoluteUrl(`/${locale}`, Astro.url, Astro.request.headers),
    },
    {
      "@type": "ListItem",
      position: 2,
      name: "Writing",
      item: absoluteUrl(`/${locale}/writing`, Astro.url, Astro.request.headers),
    },
    {
      "@type": "ListItem",
      position: 3,
      name: headline,
      item: canonicalUrl,
    },
  ],
};

const flagshipCopyByLocale: Record<LocaleKey, {
  backToWriting: string;
  share: string;
  weeklyEssay: string;
  ctaHeading: string;
  ctaBody: string;
  ctaAction: string;
  browseAll: string;
}> = {
  "en-us": {
    backToWriting: "Archive",
    share: "Share",
    weeklyEssay: "Weekly Essay",
    ctaHeading: "Get the next essay in your inbox.",
    ctaBody: "One high-quality essay per week on strategy, organizational design, and decisions that compound over time.",
    ctaAction: "Get the next essay",
    browseAll: "Browse all essays",
  },
  "en-gb": {
    backToWriting: "Archive",
    share: "Share",
    weeklyEssay: "Weekly Essay",
    ctaHeading: "Get the next essay in your inbox.",
    ctaBody: "One high-quality essay per week on strategy, organisational design, and decisions that compound over time.",
    ctaAction: "Get the next essay",
    browseAll: "Browse all essays",
  },
  "pt-br": {
    backToWriting: "Arquivo",
    share: "Compartilhar",
    weeklyEssay: "Ensaio Semanal",
    ctaHeading: "Receba o próximo ensaio no seu e-mail.",
    ctaBody: "Um ensaio de alta qualidade por semana sobre estratégia, desenho organizacional e decisões que se acumulam ao longo do tempo.",
    ctaAction: "Receber o próximo ensaio",
    browseAll: "Ver todos os ensaios",
  },
  "pt-pt": {
    backToWriting: "Arquivo",
    share: "Partilhar",
    weeklyEssay: "Ensaio Semanal",
    ctaHeading: "Receba o próximo ensaio no seu e-mail.",
    ctaBody: "Um ensaio de alta qualidade por semana sobre estratégia, desenho organizacional e decisões que se acumulam ao longo do tempo.",
    ctaAction: "Receber o próximo ensaio",
    browseAll: "Ver todos os ensaios",
  },
  "fr-fr": {
    backToWriting: "Archives",
    share: "Partager",
    weeklyEssay: "Essai Hebdomadaire",
    ctaHeading: "Recevez le prochain essai dans votre boite mail.",
    ctaBody: "Un essai de haute qualite par semaine sur la strategie, le design organisationnel et les decisions qui se composent dans la duree.",
    ctaAction: "Recevoir le prochain essai",
    browseAll: "Voir tous les essais",
  },
};

const flagshipCopy = flagshipCopyByLocale[locale];
const isFlagship = post.templateVariant === "flagship" || post.translationKey === "managerial-plasticity";
const coverImageAlt =
  post.coverImage && typeof post.coverImage === "object" && "alt" in post.coverImage && typeof post.coverImage.alt === "string"
    ? post.coverImage.alt
    : headline;
const articleDate = (() => {
  try {
    return new Intl.DateTimeFormat(mapHtmlLang(locale), {
      month: "long",
      day: "numeric",
      year: "numeric",
    }).format(new Date(post.publishedAt));
  } catch {
    return post.publishedAt;
  }
})();
const flagshipBody = transformFlagshipBody(post.body || [], locale);
const flagshipComponents = {
  block: {
    normal: FlagshipProseBlock,
    h2: FlagshipHeadingBlock,
    h3: FlagshipHeadingBlock,
    blockquote: FlagshipPullQuote,
  },
  type: {
    diagramEmbed: FlagshipDiagramBlock,
    pullQuote: FlagshipPullQuote,
    epigraph: FlagshipEpigraph,
  },
};
---

<BaseLayout
  locale={locale}
  settings={settings}
  localeLinks={localeLinks}
  title={seoTitle}
  description={seoDescription}
  canonicalPath={canonicalPath}
  isPreview={isPreview}
  structuredData={[articleSchema, breadcrumbSchema]}
  openGraph={{
    type: "article",
    title: seoTitle,
    description: seoDescription,
    image: articleOgImage,
    imageAlt: `${headline} — editorial cover`,
    publishedTime: post.publishedAt,
    modifiedTime: post.updatedAt || post.publishedAt,
    section: categoryLabel(post.category),
  }}
  hideSiteChrome={isFlagship}
>
  {isFlagship ? (
    <>
      <div
        class="flagship-essay"
        data-article-growth="root"
        data-flagship-root
        data-post-slug={post.slug}
        data-translation-key={post.translationKey}
      >
        <div class="flagship-progress" data-flagship-progress></div>

        <nav class="flagship-nav" data-flagship-nav aria-label="Article navigation">
          <a class="flagship-nav__back" href={localizedPath(locale, "writing")}>
            <svg width="14" height="10" viewBox="0 0 14 10" fill="none" aria-hidden="true">
              <path d="M5 1L1 5L5 9M1 5H13" stroke="currentColor" stroke-width="1.3" stroke-linecap="round" stroke-linejoin="round"></path>
            </svg>
            <span>{flagshipCopy.backToWriting}</span>
          </a>
          <div class="flagship-nav__title">{headline}</div>
          <a
            class="flagship-nav__share"
            href="https://www.linkedin.com/in/leocamacho/"
            target="_blank"
            rel="noopener noreferrer"
            title="Share on LinkedIn"
          >
            <svg width="13" height="13" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
              <path d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-4 0v7h-4v-7a6 6 0 0 1 6-6z"></path>
              <rect x="2" y="9" width="4" height="12"></rect>
              <circle cx="4" cy="4" r="2"></circle>
            </svg>
            <span>{flagshipCopy.share}</span>
          </a>
        </nav>

        <section class="flagship-hero">
          {post.coverImage ? (
            <img class="flagship-hero__image" src={heroImage} alt={coverImageAlt} loading="eager" width="1600" height="860" />
          ) : (
            <div class="flagship-hero__fallback">
              <span>{headline}</span>
            </div>
          )}
          <div class="flagship-hero__dissolve"></div>
          <div class="flagship-hero__nudge" aria-hidden="true">
            <div class="flagship-hero__nudge-icon">
              <svg width="18" height="22" viewBox="0 0 18 22" fill="none">
                <path d="M9 1v16M2 11l7 7 7-7" stroke="rgba(246,243,236,0.55)" stroke-width="1.3" stroke-linecap="round" stroke-linejoin="round"></path>
              </svg>
            </div>
          </div>
        </section>

        <header class="flagship-header">
          <div class="flagship-header__eyebrow">{categoryLabel(post.category)} &ensp;·&ensp; {articleDate} &ensp;·&ensp; {formatReadTime(post.readTimeMinutes)} read</div>
          <h1 class="flagship-header__title">
            {post.title}
            {post.titleEmphasis ? (
              <>
                <br />
                <em>{post.titleEmphasis}</em>
              </>
            ) : null}
          </h1>
          <p class="flagship-header__byline">By Leonardo Camacho</p>
          <div class="flagship-header__bar"></div>
        </header>

        <article class="flagship-body">
          <PortableText value={flagshipBody as never} components={flagshipComponents} />
        </article>

        <section class="flagship-cta">
          <div class="flagship-cta__label">{flagshipCopy.weeklyEssay}</div>
          <h2 class="flagship-cta__title">{flagshipCopy.ctaHeading}</h2>
          <p class="flagship-cta__body">{flagshipCopy.ctaBody}</p>
          <div class="flagship-cta__actions">
            <a class="flagship-cta__button" href={localizedPath(locale, "home")}>{flagshipCopy.ctaAction} →</a>
            <a class="flagship-cta__archive" href={localizedPath(locale, "writing")}>← {flagshipCopy.browseAll}</a>
          </div>
        </section>
      </div>

      <script>
        const growthRoot = document.querySelector('[data-article-growth="root"]');
        const trackEvent = (eventName: string, props: Record<string, string | number> = {}) => {
          if (typeof window.lcTrack !== 'function') return;
          window.lcTrack(eventName, {
            analytics_domain: 'growth',
            analytics_channel: 'client',
            ...props,
          });
        };

        if (growthRoot instanceof HTMLElement) {
          const postSlug = growthRoot.dataset.postSlug || '';
          const translationKey = growthRoot.dataset.translationKey || '';
          const startedAt = performance.now();
          let engagedTracked = false;
          let maxScrollDepth = 0;
          const progressBar = document.querySelector('[data-flagship-progress]');
          const stickyNav = document.querySelector('[data-flagship-nav]');

          const onScroll = () => {
            const root = document.scrollingElement || document.documentElement;
            const scrollTop = root.scrollTop;
            const maxScrollable = Math.max(1, root.scrollHeight - window.innerHeight);
            const depth = Math.max(0, Math.min(1, scrollTop / maxScrollable));
            if (depth > maxScrollDepth) maxScrollDepth = depth;
            if (progressBar instanceof HTMLElement) {
              progressBar.style.width = `${depth * 100}%`;
            }
            if (stickyNav instanceof HTMLElement) {
              stickyNav.dataset.visible = scrollTop > 90 ? 'true' : 'false';
            }
          };

          const maybeTrackEngagedRead = () => {
            if (engagedTracked) return;
            const elapsedSeconds = Math.floor((performance.now() - startedAt) / 1000);
            const meetsThreshold = (elapsedSeconds >= 20 && maxScrollDepth >= 0.4) || (elapsedSeconds >= 45 && maxScrollDepth >= 0.2);
            if (!meetsThreshold) return;

            engagedTracked = true;
            trackEvent('article_engaged_read', {
              surface_type: 'article',
              post_slug: postSlug,
              translation_key: translationKey,
              engaged_seconds: elapsedSeconds,
              max_scroll_depth: Number(maxScrollDepth.toFixed(2)),
            });
          };

          onScroll();
          const engagementTimer = window.setInterval(maybeTrackEngagedRead, 5000);
          window.addEventListener('scroll', () => {
            onScroll();
            maybeTrackEngagedRead();
          }, { passive: true });

          document.addEventListener('click', (event) => {
            const anchor = event.target instanceof Element ? event.target.closest('a[href]') : null;
            if (!(anchor instanceof HTMLAnchorElement)) return;

            let destination;
            try {
              destination = new URL(anchor.href, window.location.origin);
            } catch {
              return;
            }

            if (destination.origin !== window.location.origin) return;
            if (!/^\/(en-us|en-gb|pt-br|pt-pt|fr-fr)\/writing\/[^/]+$/.test(destination.pathname)) return;
            if (destination.pathname === window.location.pathname) return;

            const sourceSection = anchor.closest('.post-related')
              ? 'related'
              : anchor.closest('.flagship-body, .post-detail__content')
                ? 'article_body'
                : 'article';

            trackEvent('article_secondary_navigation_clicked', {
              surface_type: 'article',
              post_slug: postSlug,
              translation_key: translationKey,
              target_path: destination.pathname,
              source_section: sourceSection,
            });
          });

          window.addEventListener('beforeunload', () => {
            window.clearInterval(engagementTimer);
          });
        }
      </script>

      <style>
        .flagship-essay {
          --flagship-cream: #F6F3EC;
          --flagship-ink: #1A1710;
          --flagship-sub: #4a4740;
          --flagship-muted: #6E6A63;
          --flagship-ox: #6E2535;
          --flagship-border: #D8D2C8;
          --flagship-card: #F0EDE5;
          --flagship-pf: 'Playfair Display', serif;
          --flagship-dm: 'DM Sans', sans-serif;
          background: var(--flagship-cream);
          min-height: 100vh;
          color: var(--flagship-ink);
        }

        .flagship-progress {
          position: fixed;
          top: 0;
          left: 0;
          width: 0;
          height: 2px;
          background: var(--flagship-ox);
          z-index: 120;
          transition: width 0.06s linear;
          pointer-events: none;
        }

        .flagship-nav {
          position: fixed;
          top: 0;
          left: 0;
          right: 0;
          z-index: 90;
          height: 52px;
          padding: 0 clamp(20px, 3vw, 40px);
          display: grid;
          grid-template-columns: 1fr minmax(0, 38%) 1fr;
          align-items: center;
          gap: 16px;
          border-bottom: 1px solid var(--flagship-border);
          background: rgba(246, 243, 236, 0.94);
          backdrop-filter: blur(8px);
          transform: translateY(-60px);
          opacity: 0;
          transition: transform 0.28s cubic-bezier(0.25, 0.1, 0.25, 1), opacity 0.28s cubic-bezier(0.25, 0.1, 0.25, 1);
        }

        .flagship-nav[data-visible='true'] {
          transform: translateY(0);
          opacity: 1;
        }

        .flagship-nav__back,
        .flagship-nav__share {
          display: inline-flex;
          align-items: center;
          gap: 8px;
          font-family: var(--flagship-dm);
          font-size: 12px;
          letter-spacing: 0.04em;
          color: var(--flagship-muted);
          text-decoration: none;
          transition: color 0.2s ease;
          width: fit-content;
        }

        .flagship-nav__back:hover,
        .flagship-nav__back:focus-visible,
        .flagship-nav__share:hover,
        .flagship-nav__share:focus-visible {
          color: var(--flagship-ox);
        }

        .flagship-nav__share {
          justify-self: end;
          font-size: 11px;
          letter-spacing: 0.14em;
          text-transform: uppercase;
        }

        .flagship-nav__title {
          font-family: var(--flagship-pf);
          font-size: 13px;
          font-style: italic;
          color: var(--flagship-ink);
          opacity: 0.72;
          white-space: nowrap;
          overflow: hidden;
          text-overflow: ellipsis;
          text-align: center;
        }

        .flagship-hero {
          position: relative;
          width: 100%;
          height: clamp(54vh, 72vh, 82vh);
          overflow: hidden;
          background: #140f0c;
        }

        .flagship-hero__image,
        .flagship-hero__fallback {
          position: absolute;
          inset: 0;
          width: 100%;
          height: 100%;
        }

        .flagship-hero__image {
          object-fit: cover;
          object-position: center center;
          animation: flagshipHeroReveal 1.6s cubic-bezier(0.22, 0.1, 0.22, 1) both;
        }

        .flagship-hero__fallback {
          display: flex;
          align-items: center;
          justify-content: center;
          font-family: var(--flagship-pf);
          font-size: clamp(34px, 5vw, 66px);
          color: var(--flagship-cream);
          text-align: center;
          padding: 24px;
        }

        .flagship-hero__dissolve {
          position: absolute;
          inset: 0;
          background: linear-gradient(to bottom, transparent 28%, rgba(246,243,236,0.14) 52%, rgba(246,243,236,0.72) 76%, #F6F3EC 100%);
          pointer-events: none;
        }

        .flagship-hero__nudge {
          position: absolute;
          bottom: 24px;
          left: 50%;
          transform: translateX(-50%);
          display: flex;
          flex-direction: column;
          align-items: center;
          gap: 5px;
          opacity: 0;
          animation: flagshipNudgeFade 0.7s ease 1.4s forwards;
        }

        .flagship-hero__nudge-icon {
          animation: flagshipNudgeMove 1.8s ease-in-out infinite;
        }

        .flagship-header {
          max-width: 820px;
          margin: 0 auto;
          padding: clamp(12px, 2vh, 24px) clamp(24px, 5vw, 64px) 0;
          text-align: center;
        }

        .flagship-header__eyebrow {
          font-family: var(--flagship-dm);
          font-size: 11px;
          letter-spacing: 0.26em;
          text-transform: uppercase;
          color: var(--flagship-muted);
          margin-bottom: clamp(18px, 2.6vh, 30px);
        }

        .flagship-header__title {
          margin: 0 0 clamp(20px, 2.8vh, 34px);
          font-family: var(--flagship-pf);
          font-size: clamp(42px, 6.5vw, 82px);
          font-weight: 400;
          line-height: 1.03;
          letter-spacing: -0.028em;
          color: var(--flagship-ink);
        }

        .flagship-header__title em {
          color: var(--flagship-ox);
          font-style: italic;
        }

        .flagship-header__byline {
          margin: 0 0 clamp(36px, 4.8vh, 60px);
          font-family: var(--flagship-dm);
          font-size: 14px;
          letter-spacing: 0.02em;
          color: var(--flagship-muted);
        }

        .flagship-header__bar {
          width: 36px;
          height: 2px;
          margin: 0 auto clamp(44px, 5.2vh, 72px);
          background: var(--flagship-ox);
        }

        .flagship-body {
          max-width: 920px;
          margin: 0 auto;
          padding: 0 clamp(24px, 5vw, 64px);
        }

        .flagship-body :global(.flagship-prose),
        .flagship-body :global(.flagship-heading),
        .flagship-body :global(.flagship-pull-quote),
        .flagship-body :global(.flagship-epigraph) {
          max-width: 692px;
          margin-left: auto;
          margin-right: auto;
        }

        .flagship-body :global(.flagship-prose) {
          margin-top: 0;
          margin-bottom: clamp(24px, 2.8vh, 34px);
          font-family: var(--flagship-dm);
          font-size: clamp(17px, 1.22vw, 19.5px);
          line-height: 1.88;
          color: var(--flagship-sub);
        }

        .flagship-body :global(.flagship-prose--lead:first-letter) {
          float: left;
          font-family: var(--flagship-pf);
          font-size: clamp(74px, 7.8vw, 100px);
          font-weight: 700;
          line-height: 0.76;
          color: var(--flagship-ox);
          margin-right: 0.07em;
          padding-top: 0.1em;
        }

        .flagship-body :global(.flagship-prose--summary) {
          color: var(--flagship-sub);
          font-style: italic;
        }

        .flagship-body :global(.flagship-heading) {
          margin-top: clamp(52px, 6vh, 76px);
          margin-bottom: clamp(18px, 2.2vh, 26px);
          font-family: var(--flagship-pf);
          font-size: clamp(28px, 2.8vw, 36px);
          font-weight: 400;
          line-height: 1.16;
          color: var(--flagship-ink);
        }

        .flagship-body :global(.flagship-pull-quote) {
          margin-top: clamp(44px, 5vh, 64px);
          margin-bottom: clamp(44px, 5vh, 64px);
          padding-left: clamp(22px, 2.2vw, 30px);
          border-left: 3px solid var(--flagship-ox);
        }

        .flagship-body :global(.flagship-pull-quote p) {
          margin: 0;
          font-family: var(--flagship-pf);
          font-size: clamp(20px, 1.7vw, 24px);
          font-style: italic;
          line-height: 1.62;
          color: var(--flagship-ink);
        }

        .flagship-body :global(.flagship-diagram) {
          margin: clamp(56px, 6.4vh, 86px) 0;
        }

        .flagship-body :global(.flagship-diagram__frame) {
          border: 1px solid var(--flagship-border);
          background: var(--flagship-card);
          padding: clamp(20px, 3vw, 32px);
        }

        .flagship-body :global(.flagship-diagram__frame--placeholder) {
          min-height: 280px;
          display: flex;
          align-items: center;
          justify-content: center;
        }

        .flagship-body :global(.flagship-diagram__placeholder) {
          display: flex;
          flex-direction: column;
          align-items: center;
          gap: 12px;
          text-align: center;
          color: var(--flagship-muted);
          font-family: var(--flagship-dm);
        }

        .flagship-body :global(.flagship-diagram__placeholder span) {
          font-size: 11px;
          letter-spacing: 0.22em;
          text-transform: uppercase;
          color: var(--flagship-ox);
        }

        .flagship-body :global(.flagship-diagram__placeholder strong) {
          font-size: 14px;
          font-weight: 500;
          letter-spacing: 0.04em;
          text-transform: uppercase;
        }

        .flagship-body :global(.flagship-diagram__svg svg) {
          display: block;
          width: 100%;
          height: auto;
        }

        .flagship-body :global(.flagship-diagram__caption) {
          display: grid;
          gap: 8px;
          margin-top: 14px;
          font-family: var(--flagship-dm);
          font-size: 14px;
          line-height: 1.72;
          color: var(--flagship-sub);
        }

        .flagship-body :global(.flagship-diagram__label) {
          font-size: 10px;
          font-weight: 600;
          letter-spacing: 0.22em;
          text-transform: uppercase;
          color: var(--flagship-ox);
        }

        .flagship-body :global(.flagship-epigraph) {
          padding-top: clamp(64px, 7vh, 104px);
          padding-bottom: clamp(24px, 3vh, 40px);
        }

        .flagship-body :global(.flagship-epigraph__rule) {
          width: 32px;
          height: 1px;
          background: var(--flagship-border);
          margin-bottom: clamp(28px, 3.5vh, 44px);
        }

        .flagship-body :global(.flagship-epigraph p) {
          margin: 0;
          font-family: var(--flagship-pf);
          font-size: clamp(15px, 1.15vw, 17px);
          font-style: italic;
          line-height: 1.7;
          color: var(--flagship-muted);
        }

        .flagship-body :global(a) {
          color: var(--flagship-ink);
          text-underline-offset: 3px;
          text-decoration-color: var(--flagship-border);
          text-decoration-thickness: 1px;
          transition: text-decoration-color 0.2s ease;
        }

        .flagship-body :global(a:hover),
        .flagship-body :global(a:focus-visible) {
          text-decoration-color: var(--flagship-ox);
        }

        .flagship-cta {
          max-width: 680px;
          margin: clamp(88px, 10vh, 148px) auto 0;
          padding: clamp(34px, 4.8vh, 56px) clamp(24px, 5vw, 64px) clamp(44px, 6vh, 72px);
          border-top: 1px solid var(--flagship-border);
        }

        .flagship-cta__label {
          margin-bottom: clamp(12px, 1.8vh, 18px);
          font-family: var(--flagship-dm);
          font-size: 10px;
          letter-spacing: 0.22em;
          text-transform: uppercase;
          color: var(--flagship-muted);
        }

        .flagship-cta__title {
          margin: 0 0 clamp(10px, 1.6vh, 16px);
          font-family: var(--flagship-pf);
          font-size: clamp(24px, 2.6vw, 34px);
          font-weight: 400;
          line-height: 1.18;
          color: var(--flagship-ink);
          max-width: 16ch;
        }

        .flagship-cta__body {
          margin: 0 0 clamp(20px, 3vh, 30px);
          font-family: var(--flagship-dm);
          font-size: clamp(14px, 1vw, 16px);
          line-height: 1.72;
          color: var(--flagship-sub);
          max-width: 38ch;
        }

        .flagship-cta__actions {
          display: flex;
          flex-direction: row;
          flex-wrap: wrap;
          gap: 14px 22px;
          align-items: flex-start;
        }

        .flagship-cta__button {
          display: inline-flex;
          align-items: center;
          gap: 10px;
          padding: 12px 18px;
          border: 1px solid var(--flagship-border);
          background: transparent;
          color: var(--flagship-ink);
          font-family: var(--flagship-dm);
          font-size: 10px;
          font-weight: 600;
          letter-spacing: 0.14em;
          text-transform: uppercase;
          text-decoration: none;
          transition: color 0.2s ease, border-color 0.2s ease, background-color 0.2s ease;
        }

        .flagship-cta__button:hover,
        .flagship-cta__button:focus-visible {
          color: var(--flagship-ox);
          border-color: var(--flagship-ox);
          background: rgba(110, 37, 53, 0.04);
        }

        .flagship-cta__archive {
          font-family: var(--flagship-dm);
          font-size: 12px;
          color: var(--flagship-muted);
          text-decoration: none;
          border-bottom: 1px solid var(--flagship-border);
          padding-bottom: 1px;
          transition: color 0.2s ease, border-color 0.2s ease;
        }

        .flagship-cta__archive:hover,
        .flagship-cta__archive:focus-visible {
          color: var(--flagship-ox);
          border-color: var(--flagship-ox);
        }

        @keyframes flagshipHeroReveal {
          from { opacity: 0; transform: scale(1.025); }
          to { opacity: 1; transform: scale(1); }
        }

        @keyframes flagshipNudgeFade {
          from { opacity: 0; transform: translate(-50%, 6px); }
          to { opacity: 1; transform: translate(-50%, 0); }
        }

        @keyframes flagshipNudgeMove {
          0%, 100% { transform: translateY(0); }
          50% { transform: translateY(5px); }
        }

        @media (max-width: 767px) {
          .flagship-nav {
            grid-template-columns: 1fr auto;
            height: auto;
            min-height: 52px;
            padding-top: 10px;
            padding-bottom: 10px;
          }

          .flagship-nav__title {
            display: none;
          }

          .flagship-header__title {
            font-size: clamp(36px, 11vw, 52px);
          }

          .flagship-cta__actions {
            flex-direction: column;
            gap: 14px;
          }
        }
      </style>
    </>
  ) : (
    <section class="sec-featured">
      <div class="container post-detail">
        <a class="back-link" href={localizedPath(locale, "writing")}>Back to Writing</a>
        <article
          class="scroll-reveal"
          data-y="24"
          data-delay="40"
          data-article-growth="root"
          data-post-slug={post.slug}
          data-translation-key={post.translationKey}
        >
          <div class="post-detail__kicker">
            <span class={`tag ${categoryToneClass(post.category?.slug)}`}>{categoryLabel(post.category)}</span>
          </div>
          <h1 class="post-detail__title">
            {post.title} {post.titleEmphasis ? <em>{post.titleEmphasis}</em> : null}
          </h1>
          <p class="post-detail__excerpt">{post.excerpt}</p>
          <div class="meta-row">
            <span>{formatMonthYear(post.publishedAt, locale)}</span>
            <span>{formatReadTime(post.readTimeMinutes)}</span>
          </div>

          <div class="post-detail__hero post-detail__hero--offset">
            <img src={heroImage} alt={post.title} loading="eager" width="1600" height="860" />
          </div>

          <div class="post-detail__content">
            <PortableText value={post.body as never} />
          </div>

          {relatedPosts.length > 0 ? (
            <aside class="post-related">
              <h2 class="post-related__title">Related essays</h2>
              <ul class="post-related__list">
                {relatedPosts.map((related) => (
                  <li>
                    <a href={localizedPath(locale, "post", related.slug)}>
                      {related.title} {related.titleEmphasis ? <em>{related.titleEmphasis}</em> : null}
                    </a>
                  </li>
                ))}
              </ul>
            </aside>
          ) : null}
        </article>
      </div>
    </section>
  )}

  <script>
    const growthRoot = document.querySelector('[data-article-growth="root"]');
    const trackEvent = (eventName: string, props: Record<string, string | number> = {}) => {
      if (typeof window.lcTrack !== 'function') return;
      window.lcTrack(eventName, {
        analytics_domain: 'growth',
        analytics_channel: 'client',
        ...props,
      });
    };

    if (growthRoot instanceof HTMLElement) {
      const postSlug = growthRoot.dataset.postSlug || '';
      const translationKey = growthRoot.dataset.translationKey || '';
      const startedAt = performance.now();
      let engagedTracked = false;
      let maxScrollDepth = 0;

      const updateMaxScrollDepth = () => {
        const root = document.scrollingElement || document.documentElement;
        const maxScrollable = Math.max(1, root.scrollHeight - window.innerHeight);
        const depth = Math.max(0, Math.min(1, root.scrollTop / maxScrollable));
        if (depth > maxScrollDepth) {
          maxScrollDepth = depth;
        }
      };

      const maybeTrackEngagedRead = () => {
        if (engagedTracked) return;
        const elapsedSeconds = Math.floor((performance.now() - startedAt) / 1000);
        const meetsThreshold = (elapsedSeconds >= 20 && maxScrollDepth >= 0.4) || (elapsedSeconds >= 45 && maxScrollDepth >= 0.2);
        if (!meetsThreshold) return;

        engagedTracked = true;
        trackEvent('article_engaged_read', {
          surface_type: 'article',
          post_slug: postSlug,
          translation_key: translationKey,
          engaged_seconds: elapsedSeconds,
          max_scroll_depth: Number(maxScrollDepth.toFixed(2)),
        });
      };

      updateMaxScrollDepth();
      const engagementTimer = window.setInterval(maybeTrackEngagedRead, 5000);
      window.addEventListener('scroll', () => {
        updateMaxScrollDepth();
        maybeTrackEngagedRead();
      }, { passive: true });

      document.addEventListener('click', (event) => {
        const anchor = event.target instanceof Element ? event.target.closest('a[href]') : null;
        if (!(anchor instanceof HTMLAnchorElement)) return;

        let destination;
        try {
          destination = new URL(anchor.href, window.location.origin);
        } catch {
          return;
        }

        if (destination.origin !== window.location.origin) return;
        if (!/^\/(en-us|en-gb|pt-br|pt-pt|fr-fr)\/writing\/[^/]+$/.test(destination.pathname)) return;
        if (destination.pathname === window.location.pathname) return;

        const sourceSection = anchor.closest('.post-related')
          ? 'related'
          : anchor.closest('.post-detail__content, .flagship-body')
            ? 'article_body'
            : 'article';

        trackEvent('article_secondary_navigation_clicked', {
          surface_type: 'article',
          post_slug: postSlug,
          translation_key: translationKey,
          target_path: destination.pathname,
          source_section: sourceSection,
        });
      });

      window.addEventListener('beforeunload', () => {
        window.clearInterval(engagementTimer);
      });
    }
  </script>

  <style>
    .post-related {
      margin-top: 56px;
      border-top: 1px solid var(--color-line);
      padding-top: 28px;
    }

    .post-related__title {
      font-size: clamp(20px, 3vw, 28px);
      margin-bottom: 14px;
    }

    .post-related__list {
      margin: 0;
      padding: 0;
      list-style: none;
      display: grid;
      gap: 10px;
    }

    .post-related__list a {
      display: inline-flex;
      align-items: baseline;
      gap: 6px;
      border-bottom: 1px solid transparent;
      transition: border-color 180ms ease;
    }

    .post-related__list a:hover,
    .post-related__list a:focus-visible {
      border-color: var(--color-text);
    }
  </style>
</BaseLayout>
